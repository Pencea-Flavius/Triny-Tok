<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Donations that change your game' }) %>
  <link rel="stylesheet" href="/css/homepage.css">
</head>
<body>

<%- include('partials/nav') %>

<!-- HERO -->
<div class="hero-wrap">
  <div class="glow-blob blob-a"></div>
  <div class="glow-blob blob-b"></div>
  <section class="hero">

    <div>
      <h1 class="hero-title">
        Your viewers<br>
        <em>change</em> the game<br>
        in real time
      </h1>
      <p class="hero-sub">
        Transform your TikTok Live into an interactive gaming experience. TrinyTok bridges viewer donations with real-time, in-game events. They gift, you react, your stream grows.
      </p>
      <div class="hero-actions">
        <a class="btn btn-teal" href="/app">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
          Open App
        </a>
        <a class="btn btn-ghost" href="#how-it-works">
          How it works
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>

    <!-- DEMO CARD -->
    <div class="demo-box-modern">
      <div class="demo-header-modern">
        <span class="live-indicator"><span class="live-dot"></span> LIVE</span>
        <span class="demo-tag">Demonstration</span>
      </div>

      <div class="demo-body-modern">
        <!-- TIKTOK SIDE -->
        <div class="demo-tiktok-card" id="demoDonationItem">
          <div class="demo-tiktok-user">
            <img class="demo-avatar-modern" id="demoAvatar" src="https://www.tiktok.com/static/images/avatar_default.png">
            <div class="demo-user-info">
              <div class="demo-username-modern" id="demoUser">alex_gamer99</div>
              <div class="demo-msg-modern" id="demoMsg">sent Rose</div>
            </div>
          </div>
          <div class="demo-gift-display">
            <img class="demo-gift-img-modern" id="demoGiftIcon" src="">
            <div class="demo-gift-stats">
              <div class="demo-gift-title" id="demoGiftName">Rose</div>
              <div class="demo-gift-combo" id="demoRepeat">x1</div>
              <div class="demo-gift-diamonds" id="demoDiamonds">50 <svg width="12" height="12" viewBox="0 0 640 640" fill="currentColor"><path d="M232.5 136L320 229L407.5 136L232.5 136zM447.9 163.1L375.6 240L504.6 240L448 163.1zM497.9 288L142.1 288L320 484.3L497.9 288zM135.5 240L264.5 240L192.2 163.1L135.6 240zM569.8 280.1L337.8 536.1C333.3 541.1 326.8 544 320 544C313.2 544 306.8 541.1 302.2 536.1L70.2 280.1C62.5 271.6 61.9 258.9 68.7 249.7L180.7 97.7C185.2 91.6 192.4 87.9 200 87.9L440 87.9C447.6 87.9 454.8 91.5 459.3 97.7L571.3 249.7C578.1 258.9 577.4 271.6 569.8 280.1z"/></svg></div>
            </div>
          </div>
        </div>

        <!-- CONNECTION -->
        <div class="demo-connection">
          <div class="demo-arrow-circle">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <polyline points="19 12 12 19 5 12"></polyline>
            </svg>
          </div>
        </div>

        <!-- GAME SIDE -->
        <div class="demo-game-card" id="demoEvent">
          <div class="demo-game-icon-modern" id="demoGameIcon">
          </div>
          <div class="demo-game-info">
            <div class="demo-event-title-modern" id="demoTitle">Lightning strike on all players</div>
            <div class="demo-event-game-modern" id="demoDesc">Everyone gets struck instantly</div>
          </div>
        </div>
      </div>
    </div>

  </section>
</div>

<!-- HOW IT WORKS -->
<section class="section reveal" id="how-it-works">
  <div class="section-tag">How it works</div>
  <h2 class="section-title">From donation<br>to <em>event</em></h2>
  <p class="section-sub">Turn passive viewers into active participants in three simple steps.</p>

  <div class="steps">
    <div class="step">
      <div class="step-num">1</div>
      <div class="step-icon-box">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      </div>
      <div class="step-title">Setup in Seconds</div>
      <p class="step-desc">Run TrinyTok locally without latency. Connect directly to Minecraft, The Binding of Isaac, Terraria, and more.</p>
    </div>
    <div class="step">
      <div class="step-num">2</div>
      <div class="step-icon-box">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
      </div>
      <div class="step-title">Viewers Engage</div>
      <p class="step-desc">Your audience drops gifts or donations on TikTok Live. TrinyTok instantly captures and authenticates every interaction.</p>
    </div>
    <div class="step">
      <div class="step-num">3</div>
      <div class="step-icon-box">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      </div>
      <div class="step-title">The Game Reacts</div>
      <p class="step-desc">Gifts are immediately translated into spectacular in-game events. Spawn bosses, drop items, or unleash pure chaos.</p>
    </div>
  </div>
</section>

<!-- GAMES -->
<div class="games-section reveal">
  <div class="games-bg-layer" id="gamesBgLayer"></div>
  <div class="games-inner">
    <div class="section-tag">Supported games</div>
    <h2 class="section-title">Ready for your<br><em>favorite</em> titles</h2>

    <div class="games-grid">

      <!-- Minecraft -->
      <div class="game-card" data-bg="/images/games/minecraftbackground.png">
        <div class="game-thumb">
          <img src="/images/games/Minecraft.png" class="game-cover-img" alt="Minecraft Cover">
          <div class="featured-badge">
            <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            Featured
          </div>
        </div>
      </div>

      <!-- Binding of Isaac -->
      <div class="game-card" data-bg="/images/games/isaacbackground.jpg">
        <div class="game-thumb">
          <img src="/images/games/isaac.png" class="game-cover-img" alt="Binding of Isaac Cover">
        </div>
      </div>

      <!-- Repo -->
      <div class="game-card" data-bg="/images/games/repobackground.png">
        <div class="game-thumb">
          <img src="/images/games/repo.jpg" class="game-cover-img" alt="Repo Cover">
        </div>
      </div>

      <!-- Terraria -->
      <div class="game-card" data-bg="/images/games/terrariabackground.png">
        <div class="game-thumb">
          <img src="/images/games/terraria.png" class="game-cover-img" alt="Terraria Cover">
        </div>
      </div>

    </div>
  </div>
</div>

<!-- CTA -->
<section class="cta-section reveal">
  <div class="section-tag">Ready?</div>
  <h2 class="section-title">Make your stream<br><em>unpredictable</em></h2>
  <p class="section-sub">Free to start. No complicated setup. Your viewers will love it.</p>
  <div class="cta-btns">
    <a class="btn btn-teal" href="/app">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
      Open App
    </a>
    <a class="btn btn-ghost" href="#">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      View Documentation
    </a>
  </div>
</section>

<%- include('partials/footer') %>

