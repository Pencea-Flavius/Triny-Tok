    { gameIcon: `<svg width="28" height="28" viewBox="0 0 20 20" fill="currentColor" fill-rule="evenodd" xmlns="http://www.w3.org/2000/svg"><path d="M12,10 L16,10 L16,6 L12,6 L12,10 Z M4,10 L8,10 L8,6 L4,6 L4,10 Z M18,18 L14,18 L14,12 L12,12 L12,10 L8,10 L8,12 L6,12 L6,18 L2,18 L2,2 L18,2 L18,18 Z M8,18 L12,18 L12,16 L8,16 L8,18 Z M0,20 L20,20 L20,0 L0,0 L0,20 Z" /></svg>`, title: 'Summoned Creeper', desc: 'A wild Creeper appears!', user: 'muttxx3', repeat: 1 }
  ];

  // Fetch gifts and demo users
  Promise.all([
    fetch('/api/gifts').then(r => r.json()),
    fetch('/api/demo-users').then(r => r.json())
  ])
  .then(([giftsData, usersData]) => {
    const gifts = (giftsData.gifts || []).filter(g => g.image?.url_list?.[0]);
    if (gifts.length === 0) return;

    // Target specific gifts by their IDs: Doughnut(5879), Perfume(5658), Romanian Polenta(6540), Super GG(12988), Rosa(8913), Gold Boxing Gloves(5853), Creeper(54724)
    const targetGiftIds = [5879, 5658, 6540, 12988, 8913, 5853, 54724];

    // Map the demo users
    const demoUsers = {};
    if (usersData.users) {
      usersData.users.forEach(u => demoUsers[u.uniqueId] = u);
    }

    demoEvents = eventTemplates.map((tpl, i) => {
      const targetId = targetGiftIds[i];
      let g = gifts.find(gift => gift.id === targetId);
      
      // Fallback to random/sorted if still not found
      if (!g) {
        const sorted = [...gifts].sort((a, b) => (a.diamond_count || 0) - (b.diamond_count || 0));
        g = sorted[Math.min(i * Math.floor(sorted.length / targetGiftIds.length), sorted.length - 1)] || gifts[0];
      }

      const dbUser = demoUsers[tpl.user];
      const fallbackPic = 'https://www.tiktok.com/static/images/avatar_default.png';

      return {
        ...tpl,
        giftName: g.name,
        giftIcon: g.image.url_list[0],
        diamonds: g.diamond_count || 1,
        msg: `sent ${g.name}`,
        // Use demo user data if exists
        demoNickname: dbUser ? (dbUser.nickname || dbUser.uniqueId) : tpl.user,
        demoAvatar:   (dbUser && dbUser.profilePictureUrl) ? dbUser.profilePictureUrl : fallbackPic
      };
      });

      // Preload images to prevent pop-in
      demoEvents.forEach(ev => {
      if (ev.demoAvatar) new Image().src = ev.demoAvatar;
      if (ev.giftIcon) new Image().src = ev.giftIcon;
      });

      applyDemo(demoEvents[0]);
      })
      .catch(err => console.error("Demo load failed:", err));

      let idx = 0;
      const eventBox = document.getElementById('demoEvent');
      const itemBox = document.getElementById('demoDonationItem');
      const connBox = document.querySelector('.demo-connection');

      function applyDemo(ev) {
      if (!ev) return;

      // Set text immediately while hidden
      document.getElementById('demoGameIcon').innerHTML     = ev.gameIcon;
      document.getElementById('demoTitle').textContent      = ev.title;
      document.getElementById('demoDesc').textContent       = ev.desc;

      document.getElementById('demoAvatar').src             = ev.demoAvatar || 'https://www.tiktok.com/static/images/avatar_default.png';
      document.getElementById('demoUser').textContent       = ev.demoNickname || ev.user;
      document.getElementById('demoMsg').textContent        = ev.msg;
      document.getElementById('demoGiftName').textContent   = ev.giftName || '';
      document.getElementById('demoGiftIcon').src           = ev.giftIcon || '';
      document.getElementById('demoRepeat').textContent     = 'x' + (ev.repeat || 1);

      const diamondSvg = '<svg width="12" height="12" viewBox="0 0 640 640" fill="currentColor"><path d="M232.5 136L320 229L407.5 136L232.5 136zM447.9 163.1L375.6 240L504.6 240L448 163.1zM497.9 288L142.1 288L320 484.3L497.9 288zM135.5 240L264.5 240L192.2 163.1L135.6 240zM569.8 280.1L337.8 536.1C333.3 541.1 326.8 544 320 544C313.2 544 306.8 541.1 302.2 536.1L70.2 280.1C62.5 271.6 61.9 258.9 68.7 249.7L180.7 97.7C185.2 91.6 192.4 87.9 200 87.9L440 87.9C447.6 87.9 454.8 91.5 459.3 97.7L571.3 249.7C578.1 258.9 577.4 271.6 569.8 280.1z"/></svg>';
      document.getElementById('demoDiamonds').innerHTML     = ((ev.diamonds || 0) * (ev.repeat || 1)).toLocaleString() + diamondSvg;

      itemBox.style.transition = 'opacity 0.4s ease-out, transform 0.4s ease-out';      if (connBox) connBox.style.transition = 'opacity 0.3s ease-out';
      eventBox.style.transition = 'opacity 0.4s ease-out, transform 0.4s ease-out';

      // Give browser a moment to apply the new image src before fading in
      setTimeout(() => {
      // 1) Fade IN the donation
      itemBox.style.opacity = '1';
      itemBox.style.transform = 'none';

      // 2) Fade IN the connection line
      setTimeout(() => {
        if (connBox) connBox.style.opacity = '1';
      }, 300);

      // 3) Fade IN the in-game event to show causality
      setTimeout(() => {
        eventBox.style.opacity = '1';
        eventBox.style.transform = 'none';
      }, 600);
      }, 50);
      }
  function nextDemo() {
    if (demoEvents.length === 0) return;
    idx = (idx + 1) % demoEvents.length;
    const ev = demoEvents[idx];

    // Fade OUT all
    itemBox.style.opacity = '0';
    itemBox.style.transform = 'translateY(12px)';
    if (connBox) connBox.style.opacity = '0';
    eventBox.style.opacity = '0';
    eventBox.style.transform = 'translateY(12px)';
    
    // Wait for fade OUT to finish, then apply new demo
    setTimeout(() => {
      applyDemo(ev);
    }, 400);
  }

  setInterval(nextDemo, 4500);
  // ── GAMES BACKGROUND HOVER CROSSFADE ──
  const gamesBgLayer = document.getElementById('gamesBgLayer');
  gamesBgLayer.style.opacity = '1';
  gamesBgLayer.style.backgroundImage = 'none';

  const bgWrapper = document.createElement('div');
  Object.assign(bgWrapper.style, { position: 'absolute', inset: '0', zIndex: '-1' });
  gamesBgLayer.appendChild(bgWrapper);

  const bgLayers = [document.createElement('div'), document.createElement('div')];
  let activeBgIdx = 0;

  bgLayers.forEach(layer => {
    Object.assign(layer.style, {
      position: 'absolute', inset: '0',
      backgroundSize: 'cover', backgroundPosition: 'center',
      opacity: '0', transition: 'opacity 0.45s ease'
    });
    bgWrapper.appendChild(layer);
  });

  document.querySelectorAll('.game-card').forEach(card => {
    card.addEventListener('mouseenter', () => {
      const bg = card.getAttribute('data-bg');
      if (bg) {
        activeBgIdx = 1 - activeBgIdx;
        bgLayers[activeBgIdx].style.backgroundImage = `url('${bg}')`;
        bgLayers[activeBgIdx].style.opacity = '0.35';
        bgLayers[1 - activeBgIdx].style.opacity = '0';
      }
    });
    card.addEventListener('mouseleave', () => {
      bgLayers[0].style.opacity = '0';
      bgLayers[1].style.opacity = '0';
    });
  });
</script>
</body>
</html>
