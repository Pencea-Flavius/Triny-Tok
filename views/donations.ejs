<%
const diamondSvg = '<svg width="11" height="11" viewBox="0 0 640 640" fill="currentColor" style="vertical-align:middle;margin-right:2px;flex-shrink:0;"><path d="M232.5 136L320 229L407.5 136L232.5 136zM447.9 163.1L375.6 240L504.6 240L448 163.1zM497.9 288L142.1 288L320 484.3L497.9 288zM135.5 240L264.5 240L192.2 163.1L135.6 240zM569.8 280.1L337.8 536.1C333.3 541.1 326.8 544 320 544C313.2 544 306.8 541.1 302.2 536.1L70.2 280.1C62.5 271.6 61.9 258.9 68.7 249.7L180.7 97.7C185.2 91.6 192.4 87.9 200 87.9L440 87.9C447.6 87.9 454.8 91.5 459.3 97.7L571.3 249.7C578.1 258.9 577.4 271.6 569.8 280.1z"/></svg>';
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Donation History' }) %>
  <link rel="stylesheet" href="/css/login.css">
  <style>
    .page-wrap {
      min-height: 100vh;
      padding: 90px 48px 80px;
      max-width: 960px;
      margin: 0 auto;
    }

    .page-back {
      display: inline-flex; align-items: center; gap: 7px;
      font-size: 13px; font-weight: 600; color: var(--muted);
      text-decoration: none; margin-bottom: 36px;
      transition: color 0.15s;
    }
    .page-back:hover { color: var(--teal); }

    .page-header {
      display: flex; align-items: flex-end; justify-content: space-between;
      margin-bottom: 32px; flex-wrap: wrap; gap: 16px;
    }
    .page-title {
      font-size: 28px; font-weight: 900; letter-spacing: -0.8px;
      line-height: 1;
    }
    .page-title span { color: var(--teal); }

    .stat-pill {
      display: flex; align-items: center; gap: 8px;
      padding: 8px 14px; border-radius: 10px;
      background: var(--bg2); border: 1px solid var(--border);
      font-size: 13px; font-weight: 700; color: var(--text);
    }
    .stat-pill .stat-label { color: var(--muted); font-weight: 600; }

    /* Table */
    .table-wrap {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: 16px; overflow: hidden;
    }
    .hist-table {
      width: 100%; border-collapse: collapse;
    }
    .hist-table thead th {
      padding: 14px 20px;
      font-size: 10px; font-weight: 800; letter-spacing: 1.2px;
      text-transform: uppercase; color: var(--dim);
      border-bottom: 1px solid rgba(255,255,255,0.04);
      text-align: left;
    }
    .hist-table thead th:last-child { text-align: right; }
    .hist-table tbody tr {
      border-bottom: 1px solid rgba(255,255,255,0.03);
      transition: background 0.12s;
    }
    .hist-table tbody tr:last-child { border-bottom: none; }
    .hist-table tbody tr:hover { background: rgba(255,255,255,0.025); }
    .hist-table td { padding: 13px 20px; vertical-align: middle; }

    .time-cell {
      font-size: 12px; color: var(--dim); white-space: nowrap; min-width: 80px;
    }
    .donor-cell {
      display: flex; align-items: center; gap: 10px; min-width: 160px;
    }
    .donor-avatar {
      width: 32px; height: 32px; border-radius: 50%;
      object-fit: cover; flex-shrink: 0;
      border: 1px solid rgba(0,242,234,0.12);
    }
    .donor-avatar-fallback {
      width: 32px; height: 32px; border-radius: 50%;
      display: none; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 900; color: var(--teal);
      background: rgba(0,242,234,0.08);
      border: 1px solid rgba(0,242,234,0.12);
      flex-shrink: 0;
    }
    .donor-name { font-size: 13px; font-weight: 700; color: var(--text); }
    .donor-nick { font-size: 11px; color: var(--muted); margin-top: 1px; }

    .gift-cell {
      display: flex; align-items: center; gap: 8px;
    }
    .gift-icon {
      width: 28px; height: 28px; border-radius: 6px;
      object-fit: cover; flex-shrink: 0;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
    }
    .gift-name { font-size: 13px; font-weight: 600; color: var(--text); }

    .count-badge {
      display: inline-flex; align-items: center; justify-content: center;
      padding: 2px 8px; border-radius: 20px;
      font-size: 11px; font-weight: 800;
      background: rgba(0,242,234,0.1); color: var(--teal);
      border: 1px solid rgba(0,242,234,0.15);
    }

    .diamonds-cell {
      text-align: right; font-size: 14px; font-weight: 900; color: var(--teal);
      white-space: nowrap;
    }
    .diamonds-cell small { font-size: 11px; font-weight: 600; opacity: 0.6; }

    .empty-state {
      padding: 72px 24px; text-align: center; color: var(--dim);
    }
    .empty-state svg { opacity: 0.3; margin-bottom: 16px; }
    .empty-state p { font-size: 14px; }

    /* Pagination */
    .pagination {
      display: flex; align-items: center; justify-content: center;
      gap: 8px; margin-top: 28px;
    }
    .page-btn {
      display: inline-flex; align-items: center; justify-content: center;
      width: 36px; height: 36px; border-radius: 8px;
      font-size: 13px; font-weight: 700; text-decoration: none;
      border: 1px solid var(--border); color: var(--muted);
      background: var(--bg2); transition: all 0.15s;
    }
    .page-btn:hover { border-color: var(--teal); color: var(--teal); }
    .page-btn.active { background: var(--teal); color: #060912; border-color: var(--teal); }
    .page-btn.disabled { opacity: 0.3; pointer-events: none; }

    @media (max-width: 640px) {
      .page-wrap { padding: 90px 20px 60px; }
      .hist-table thead { display: none; }
      .hist-table td { padding: 11px 14px; }
      .time-cell { display: none; }
    }
  </style>
</head>
<body>
<%- include('partials/nav') %>

<div class="page-wrap">
  <div class="glow-blob blob-a" style="opacity:0.04;"></div>

  <a href="/account" class="page-back">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    Back to account
  </a>

  <div class="page-header">
    <div>
      <div class="page-title">Donation <span>History</span></div>
      <div style="font-size:13px;color:var(--muted);margin-top:6px;">Every gift received across all your streams</div>
    </div>
    <div class="stat-pill">
      <span class="stat-label">Total donations</span>
      <span><%= total.toLocaleString() %></span>
    </div>
  </div>

  <% if (donations.length === 0) { %>
  <div class="table-wrap">
    <div class="empty-state">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
      <p>No donations recorded yet. Go live and start collecting gifts!</p>
    </div>
  </div>
  <% } else { %>

  <div class="table-wrap">
    <table class="hist-table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Donor</th>
          <th>Gift</th>
          <th>Count</th>
          <th style="text-align:right;">Diamonds</th>
        </tr>
      </thead>
      <tbody>
        <% donations.forEach((d, i) => {
          const avatarId = 'ha-' + i;
          const fallbackId = 'haf-' + i;
          const name = d.uniqueId || 'Unknown';
          const initial = (d.nickname || d.uniqueId || '?').charAt(0).toUpperCase();
          const ts = new Date(d.timestamp);
          const now = new Date();
          const diffMs = now - ts;
          const diffMins = Math.floor(diffMs / 60000);
          const diffHrs  = Math.floor(diffMins / 60);
          const diffDays = Math.floor(diffHrs / 24);
          let timeAgo;
          if (diffMins < 1)       timeAgo = 'just now';
          else if (diffMins < 60) timeAgo = diffMins + 'm ago';
          else if (diffHrs < 24)  timeAgo = diffHrs + 'h ago';
          else if (diffDays < 7)  timeAgo = diffDays + 'd ago';
          else timeAgo = ts.toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' });
        %>
        <tr>
          <td class="time-cell"><%= timeAgo %></td>
          <td>
            <div class="donor-cell">
              <% if (d.uniqueId) { %>
              <img
                src="https://unavatar.io/tiktok/<%= d.uniqueId %>"
                alt="<%= name %>"
                class="donor-avatar"
                id="<%= avatarId %>"
                onerror="this.style.display='none';document.getElementById('<%= fallbackId %>').style.display='flex';"
              >
              <% } %>
              <div class="donor-avatar-fallback" id="<%= fallbackId %>" style="<%= !d.uniqueId ? 'display:flex;' : '' %>">
                <%= initial %>
              </div>
              <div>
                <div class="donor-name">@<%= name %></div>
                <% if (d.nickname && d.nickname !== d.uniqueId) { %>
                <div class="donor-nick"><%= d.nickname %></div>
                <% } %>
              </div>
            </div>
          </td>
          <td>
            <div class="gift-cell">
              <% if (d.giftImage) { %>
              <img src="<%= d.giftImage %>" alt="<%= d.giftName %>" class="gift-icon">
              <% } %>
              <span class="gift-name"><%= d.giftName || 'Unknown gift' %></span>
            </div>
          </td>
          <td>
            <% if (d.count > 1) { %>
            <span class="count-badge">×<%= d.count %></span>
            <% } else { %>
            <span style="font-size:12px;color:var(--dim);">×1</span>
            <% } %>
          </td>
          <td class="diamonds-cell"><%- diamondSvg %> <%= (d.totalDiamonds || 0).toLocaleString() %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% const totalPages = Math.ceil(total / pageSize); %>
  <% if (totalPages > 1) { %>
  <div class="pagination">
    <a href="?page=<%= page - 1 %>" class="page-btn <%= page <= 1 ? 'disabled' : '' %>">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </a>
    <% for (let p = Math.max(1, page - 2); p <= Math.min(totalPages, page + 2); p++) { %>
    <a href="?page=<%= p %>" class="page-btn <%= p === page ? 'active' : '' %>"><%= p %></a>
    <% } %>
    <a href="?page=<%= page + 1 %>" class="page-btn <%= page >= totalPages ? 'disabled' : '' %>">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </a>
  </div>
  <% } %>

  <% } %>
</div>

<%- include('partials/footer') %>
</body>
</html>
