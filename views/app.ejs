<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('partials/head', { title: 'Dashboard' }) %>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet">
    <link rel="stylesheet" href="/css/app.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.4.1/socket.io.min.js"></script>
    <script type="module" src="/js/app.js"></script>
</head>

<body class="sec-connect">
  <div class="app-layout">

    <!-- ═══════════════════════════════════
       CATEGORY RAIL (leftmost, 76px)
  ═══════════════════════════════════ -->
    <nav class="cat-rail" id="catRail">

      <!-- Logo -->
      <div class="rail-logo">TT</div>

      <!-- Connection -->
      <button class="cat-btn active" data-section="connect" id="cat-connect" title="Connection">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
          stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
        </svg>
        <span class="cat-label">Live</span>
      </button>

      <div class="rail-divider"></div>

      <!-- Monitor -->
      <button class="cat-btn" data-section="monitor" id="cat-monitor" title="Monitor">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
          stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2" />
          <line x1="8" y1="21" x2="16" y2="21" />
          <line x1="12" y1="17" x2="12" y2="21" />
        </svg>
        <span class="cat-label">Monitor</span>
      </button>

      <div class="rail-divider"></div>

      <!-- Game Bridge -->
      <button class="cat-btn" data-section="game" id="cat-game" title="Game Bridge">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
          stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="6" width="20" height="12" rx="2" />
          <path d="M12 12h.01" />
          <path d="M7 12h2" />
          <path d="M17 10v4" />
          <path d="M15 12h2" />
        </svg>
        <span class="cat-label">Game</span>
      </button>

      <div class="rail-spacer"></div>

      <!-- OBS -->
      <button class="obs-btn" onclick="window.open('/obs.html','_blank')" title="Open OBS Overlay">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
          stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10" />
          <circle cx="12" cy="12" r="4" />
          <line x1="4.93" y1="4.93" x2="9.17" y2="9.17" />
          <line x1="14.83" y1="14.83" x2="19.07" y2="19.07" />
          <line x1="14.83" y1="9.17" x2="19.07" y2="4.93" />
          <line x1="4.93" y1="19.07" x2="9.17" y2="14.83" />
        </svg>
        <span class="cat-label">OBS</span>
      </button>

    </nav>

    <!-- ═══════════════════════════════════
       SUBMENU PANEL (218px)
  ═══════════════════════════════════ -->
    <aside class="sub-panel" id="subPanel">

      <div class="sub-header">
        <div class="sub-section-label" id="subSectionLabel">Connection</div>
        <div class="sub-section-desc" id="subSectionDesc">TikTok stream &amp; status</div>
      </div>

      <nav class="sub-nav">

        <!-- Connect group -->
        <div class="sub-group visible" data-section="connect">
          <button class="sub-item active" data-tab="connect" id="connectTab">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.42C2 2.19 2.95 2 3.71 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
            TikTok Connect
          </button>
        </div>

        <!-- Monitor group -->
        <div class="sub-group" data-section="monitor">
          <button class="sub-item" data-tab="chat" id="chatTab">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            </svg>
            Live Chat
          </button>
          <button class="sub-item" data-tab="tracker" id="trackerTab">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 12 20 22 4 22 4 12" />
              <rect x="2" y="7" width="20" height="5" />
              <line x1="12" y1="22" x2="12" y2="7" />
              <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z" />
              <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z" />
            </svg>
            Gift Log
          </button>
          <button class="sub-item" data-tab="topDonors" id="topDonorsTab">
            <svg width="14" height="14" viewBox="0 0 640 640" fill="currentColor"
              style="margin-right: 6px; opacity: 0.85;">
              <path
                d="M232.5 136L320 229L407.5 136L232.5 136zM447.9 163.1L375.6 240L504.6 240L448 163.1zM497.9 288L142.1 288L320 484.3L497.9 288zM135.5 240L264.5 240L192.2 163.1L135.6 240zM569.8 280.1L337.8 536.1C333.3 541.1 326.8 544 320 544C313.2 544 306.8 541.1 302.2 536.1L70.2 280.1C62.5 271.6 61.9 258.9 68.7 249.7L180.7 97.7C185.2 91.6 192.4 87.9 200 87.9L440 87.9C447.6 87.9 454.8 91.5 459.3 97.7L571.3 249.7C578.1 258.9 577.4 271.6 569.8 280.1z" />
            </svg>
            Top Donators
          </button>
        </div>

        <!-- Game group — console accordion -->
        <div class="sub-group" data-section="game">

          <!-- Minecraft console accordion -->
          <div class="sub-console" id="consoleMinecraft">
            <button class="sub-console-header" id="consoleMinecraftBtn">
              <div class="sub-console-header-left">
                <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor" fill-rule="evenodd"
                  xmlns="http://www.w3.org/2000/svg">
                  <path
                    d="M12,10 L16,10 L16,6 L12,6 L12,10 Z M4,10 L8,10 L8,6 L4,6 L4,10 Z M18,18 L14,18 L14,12 L12,12 L12,10 L8,10 L8,12 L6,12 L6,18 L2,18 L2,2 L18,2 L18,18 Z M8,18 L12,18 L12,16 L8,16 L8,18 Z M0,20 L20,20 L20,0 L0,0 L0,20 Z" />
                </svg>
                <span>Minecraft</span>
              </div>
              <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6" />
              </svg>
            </button>
            <div class="sub-console-items">
              <button class="sub-item sub-console-item" data-tab="minecraft" id="minecraftTab">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="7" height="7" rx="1" />
                  <rect x="15" y="3" width="7" height="7" rx="1" />
                  <rect x="15" y="14" width="7" height="7" rx="1" />
                  <rect x="2" y="14" width="7" height="7" rx="1" />
                </svg>
                Settings
              </button>
              <button class="sub-item sub-console-item" data-tab="commands" id="commandsTab">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="4 17 10 11 4 5" />
                  <line x1="12" y1="19" x2="20" y2="19" />
                </svg>
                Gift Commands
              </button>
            </div>
          </div>

        </div>

      </nav>

      <div class="sub-footer">
        <a href="/">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
          </svg>
          Back to Homepage
        </a>
      </div>

    </aside>

    <!-- ═══════════════════════════════════
       CONTENT AREA (right, flex: 1)
  ═══════════════════════════════════ -->
    <div class="content-wrap">

      <!-- Top bar (thin breadcrumb + status) -->
      <header class="top-bar">
        <div class="breadcrumb">
          <span id="breadSection">Connection</span>
          <span class="breadcrumb-sep">/</span>
          <span class="breadcrumb-page" id="breadPage">TikTok Connect</span>
        </div>

        <div class="top-bar-right">
          <div class="room-stat">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
              <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
            <b id="viewerCount">0</b>
          </div>
          <div class="room-stat">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path
                d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
            </svg>
            <b id="likeCount">0</b>
          </div>
          <div class="status-pill">
            <div class="status-dot" id="statusDot"></div>
            <span id="statusText">Not Connected</span>
          </div>
        </div>
      </header>

      <!-- Scrollable workspace -->
      <div class="workspace">

        <!-- ════ CONNECTION ════ -->
        <div id="connectContent" class="tab-content active">
          <div class="page-header">
            <div>
              <div class="page-eyebrow"><span class="eyebrow-dot"></span>TikTok Live</div>
              <h1 class="page-h1">Connection</h1>
              <p class="page-sub">Link TrinyTok to a live TikTok stream.</p>
            </div>
          </div>

          <hr class="accent-rule">

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;flex:1;min-height:0;">

            <!-- Left: form -->
            <div style="display:flex;flex-direction:column;gap:16px;">
              <div class="card">
                <div class="field">
                  <label class="field-label">Streamer Username</label>
                  <div style="display:flex;gap:10px;margin-top:6px;">
                    <input type="text" id="uniqueIdInput" placeholder="@username" style="flex:1;">
                    <button class="btn-primary" id="connectButton" style="min-width:120px;">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                      </svg>
                      Connect
                    </button>
                  </div>
                  <p style="font-size:12px;color:var(--dim);margin-top:8px;">The streamer must be currently <strong
                      style="color:var(--danger)">LIVE</strong> on TikTok.</p>
                </div>
              </div>

              <div class="card-tip">
                <div class="tip-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                    stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent);">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="16" x2="12" y2="12" />
                    <line x1="12" y1="8" x2="12.01" y2="8" />
                  </svg>
                </div>
                <div>
                  <div class="tip-title">How it works</div>
                  <div class="tip-desc">Enter a TikTok username and click Connect. TrinyTok will listen to all gifts,
                    chat, and engagement events in real time — no cloud required.</div>
                </div>
              </div>
            </div>

            <!-- Right: live session stats -->
            <div style="display:flex;flex-direction:column;gap:14px;">
              <div class="card">
                <div
                  style="font-size:10.5px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--dim);margin-bottom:18px;">
                  Live Session</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                  <div
                    style="background:var(--bg3);border:1px solid var(--border);border-radius:var(--r-md);padding:16px;">
                    <div
                      style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.8px;color:var(--dim);margin-bottom:6px;">
                      Viewers</div>
                    <div style="font-size:26px;font-weight:900;letter-spacing:-1px;color:var(--accent);"
                      id="sessionViewers">0</div>
                  </div>
                  <div
                    style="background:var(--bg3);border:1px solid var(--border);border-radius:var(--r-md);padding:16px;">
                    <div
                      style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.8px;color:var(--dim);margin-bottom:6px;">
                      Likes</div>
                    <div style="font-size:26px;font-weight:900;letter-spacing:-1px;color:var(--accent);"
                      id="sessionLikes">0</div>
                  </div>
                  <div
                    style="background:var(--bg3);border:1px solid var(--border);border-radius:var(--r-md);padding:16px;">
                    <div
                      style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.8px;color:var(--dim);margin-bottom:6px;">
                      Diamonds</div>
                    <div style="font-size:26px;font-weight:900;letter-spacing:-1px;color:var(--accent);"
                      id="sessionDiamonds">0</div>
                  </div>
                  <div
                    style="background:var(--bg3);border:1px solid var(--border);border-radius:var(--r-md);padding:16px;">
                    <div
                      style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.8px;color:var(--dim);margin-bottom:6px;">
                      Est. USD</div>
                    <div style="font-size:26px;font-weight:900;letter-spacing:-1px;color:var(--accent);"
                      id="sessionUSD">$0.00</div>
                  </div>
                </div>

                <div
                  style="margin-top:18px;padding-top:16px;border-top:1px solid var(--border);display:flex;flex-direction:column;gap:10px;">
                  <div style="display:flex;justify-content:space-between;align-items:center;font-size:12.5px;">
                    <span style="color:var(--dim);">Connection status</span>
                    <span id="sessionStatus" style="font-weight:700;color:var(--danger);">Disconnected</span>
                  </div>
                  <div style="display:flex;justify-content:space-between;align-items:center;font-size:12.5px;">
                    <span style="color:var(--dim);">Gifts received</span>
                    <span id="sessionGifts" style="font-weight:700;color:var(--text);">0</span>
                  </div>
                  <div style="display:flex;justify-content:space-between;align-items:center;font-size:12.5px;">
                    <span style="color:var(--dim);">Chat messages</span>
                    <span id="sessionChats" style="font-weight:700;color:var(--text);">0</span>
                  </div>
                  <div style="display:flex;justify-content:space-between;align-items:center;font-size:12.5px;">
                    <span style="color:var(--dim);">Follows this session</span>
                    <span id="sessionFollows" style="font-weight:700;color:var(--accent);">0</span>
                  </div>
                </div>
              </div>

              <!-- ════ RECENT FOLLOWERS ════ -->
              <div class="card" style="margin-top: 0; margin-bottom: 24px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                  <div
                    style="font-size:10.5px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--dim);">
                    Recent Followers</div>
                  <div style="display:flex;align-items:center;gap:6px;">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="var(--accent)"
                      stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                      <circle cx="9" cy="7" r="4" />
                      <line x1="19" y1="8" x2="19" y2="14" />
                      <line x1="22" y1="11" x2="16" y2="11" />
                    </svg>
                    <span id="sessionFollowsBadge" style="font-size:11px;font-weight:800;color:var(--accent);">0</span>
                    <span style="font-size:11px;color:var(--dim);">this session</span>
                  </div>
                </div>

                <div id="recentFollowersList" style="display:flex;flex-direction:column;gap:10px;">
                  <div class="follower-placeholder"
                    style="text-align:center;padding:16px 0;font-size:12px;color:var(--dim);">No new followers yet</div>
                </div>
              </div>

            </div> <!-- End right flex column -->
          </div> <!-- End display:grid -->
        </div> <!-- End connectContent -->


        <!-- ════ LIVE CHAT ════ -->
        <div id="chatContent" class="tab-content">
          <div class="page-header">
            <div>
              <div class="page-eyebrow"><span class="eyebrow-dot"></span>Monitor</div>
              <h1 class="page-h1">Live Chat</h1>
              <p class="page-sub">Real-time messages from the TikTok stream.</p>
            </div>
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
              <input type="checkbox" id="chatAutoScroll" checked
                style="accent-color:var(--accent);width:16px;height:16px;cursor:pointer;">
              <span style="font-size:12px;font-weight:600;color:var(--dim);">Auto-scroll</span>
            </label>
          </div>
          <hr class="accent-rule">
          <div class="feed-wrap">
            <div class="chatcontainer">
              <div class="static placeholder">Waiting for messages...</div>
            </div>
          </div>
        </div>

        <!-- ════ GIFT LOG ════ -->
        <div id="trackerContent" class="tab-content">
          <div class="page-header">
            <div>
              <div class="page-eyebrow"><span class="eyebrow-dot"></span>Monitor</div>
              <h1 class="page-h1">Gift Log</h1>
              <p class="page-sub">Every gift received in this session.</p>
            </div>
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
              <input type="checkbox" id="giftAutoScroll" checked
                style="accent-color:var(--accent);width:16px;height:16px;cursor:pointer;">
              <span style="font-size:12px;font-weight:600;color:var(--dim);">Auto-scroll</span>
            </label>
          </div>
          <hr class="accent-rule">
          <div class="feed-wrap">
            <div class="giftcontainer">
              <div class="static placeholder">Waiting for gifts...</div>
            </div>
          </div>
        </div>

        <!-- ════ TOP DONATORS ════ -->
        <div id="topDonorsContent" class="tab-content">
          <div class="page-header">
            <div>
              <div class="page-eyebrow"><span class="eyebrow-dot"></span>Ranking</div>
              <h1 class="page-h1">Top Donators</h1>
              <p class="page-sub">Session leaderboard, sorted by diamonds.</p>
            </div>
            <div class="page-actions">
              <button class="btn-secondary btn-sm" id="refreshTopDonorsBtn">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                  stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="23 4 23 10 17 10" />
                  <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
                </svg>
                Refresh
              </button>
            </div>
          </div>
          <hr class="accent-rule">

          <div class="stats-row">
            <div class="stat-card">
              <div class="stat-label" style="display:flex;align-items:center;gap:6px;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 3 20 3 14 9 20 15 6 15" />
                  <line x1="6" y1="3" x2="6" y2="21" />
                </svg>
                Tracked Diamonds
              </div>
              <div class="stat-value" id="totalDiamonds">0</div>
            </div>
            <div class="stat-card">
              <div class="stat-label" style="display:flex;align-items:center;gap:6px;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="1" x2="12" y2="23" />
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                </svg>
                Est. Earnings (USD)
              </div>
              <div class="stat-value" id="totalUSD">$0.00</div>
            </div>
          </div>

          <button class="btn-secondary" id="syncInitialBtn"
            style="display:none;width:100%;border-style:dashed;justify-content:center;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="23 4 23 10 17 10" />
              <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
            </svg>
            Sync Initial Top Donors
          </button>

          <div class="table-wrap">
            <div class="data-table-container">
              <table class="data-table">
                <thead>
                  <tr>
                    <th style="width:54px;">#</th>
                    <th>User</th>
                    <th>Diamonds</th>
                    <th>Last Gift</th>
                  </tr>
                </thead>
                <tbody id="topDonorsTableBody">
                  <tr>
                    <td colspan="4" style="text-align:center;padding:40px;color:var(--dim);">No data yet</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- ════ MINECRAFT ════ -->
        <div id="minecraftContent" class="tab-content">
          <div class="page-header">
            <div>
              <div class="page-eyebrow"><span class="eyebrow-dot"></span>Game Bridge</div>
              <h1 class="page-h1">Minecraft</h1>
              <p class="page-sub">Connect to your server via RCON.</p>
            </div>
          </div>
          <hr class="accent-rule">

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;flex:1;min-height:0;">

            <!-- Left: server config -->
            <div style="display:flex;flex-direction:column;gap:16px;">
              <div class="card">
                <div
                  style="font-size:10.5px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--dim);margin-bottom:18px;">
                  Server Configuration</div>

                <div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:20px;">
                  <div class="field" style="flex:2;min-width:140px;">
                    <label class="field-label">Host Address</label>
                    <input type="text" id="minecraftHost" placeholder="localhost" style="margin-top:6px;">
                  </div>
                  <div class="field" style="flex:1;min-width:90px;">
                    <label class="field-label">RCON Port</label>
                    <input type="number" id="minecraftPort" placeholder="25575" style="margin-top:6px;">
                  </div>
                </div>

                <div class="field" style="margin-bottom:18px;">
                  <label class="field-label">RCON Password</label>
                  <input type="password" id="minecraftPassword" placeholder="••••••••" style="margin-top:6px;">
                </div>

                <div class="field" style="margin-bottom:22px;">
                  <label class="field-label">Target Players (one per line)</label>
                  <textarea id="targetPlayersInput" placeholder="Steve&#10;Alex" rows="3"
                    style="font-family:'JetBrains Mono',monospace;margin-top:6px;"></textarea>
                  <p style="font-size:12px;color:var(--dim);margin-top:6px;">Random pick per command via
                    <code>{playername}</code>.
                  </p>
                </div>

                <div
                  style="display:flex;align-items:center;justify-content:space-between;padding-top:16px;border-top:1px solid var(--border);">
                  <div class="mc-status" id="mcStatusLabel">
                    <div class="mc-dot" id="mcStatusDot"></div>
                    <span id="mcStatusText"
                      style="font-weight:700;color:var(--danger);font-size:13px;text-transform:uppercase;letter-spacing:0.5px;">Disconnected</span>
                  </div>
                  <div style="display:flex;align-items:center;gap:12px;">
                    <label
                      style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:13px;font-weight:500;color:var(--muted);">
                      <input type="checkbox" id="autoConnectRcon"
                        style="width:15px;height:15px;accent-color:var(--accent);">
                      Auto-Connect
                    </label>
                    <button class="btn-primary" id="mcConnectBtn">Connect Bridge</button>
                  </div>
                </div>
              </div>

              <div class="card-tip" style="border-left-color:#4ade80;">
                <div class="tip-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                    stroke-linecap="round" stroke-linejoin="round" style="color:#4ade80;">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
                  </svg>
                </div>
                <div>
                  <div class="tip-title">Setup</div>
                  <div class="tip-desc">Set <code>enable-rcon=true</code> and <code>rcon.password</code> in
                    <code>server.properties</code>, then restart.
                  </div>
                </div>
              </div>
            </div>

            <!-- Right: RCON activity log -->
            <div style="display:flex;flex-direction:column;gap:14px;">
              <div class="card" style="flex:1;display:flex;flex-direction:column;min-height:0;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                  <div
                    style="font-size:10.5px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--dim);">
                    RCON Activity Log</div>
                  <button onclick="document.getElementById('rconLog').innerHTML='';"
                    style="font-size:11px;color:var(--dim);background:transparent;border:none;cursor:pointer;font-family:inherit;padding:2px 8px;border-radius:4px;transition:color 0.15s;"
                    onmouseover="this.style.color='var(--text)'"
                    onmouseout="this.style.color='var(--dim)'">Clear</button>
                </div>
                <div id="rconLog"
                  style="flex:1;overflow-y:auto;font-family:'JetBrains Mono',monospace;font-size:12px;line-height:1.7;color:var(--muted);background:var(--bg);border-radius:var(--r-md);padding:12px 14px;min-height:180px;">
                  <span style="color:var(--dim);">-- RCON log will appear here when connected --</span>
                </div>
                <div style="margin-top:12px;display:flex;gap:8px;">
                  <input type="text" id="rconCmdInput" placeholder="Run command manually..."
                    style="flex:1;font-family:'JetBrains Mono',monospace;font-size:13px;">
                  <button class="btn-primary btn-sm" id="rconSendBtn">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                      stroke-linecap="round" stroke-linejoin="round">
                      <line x1="22" y1="2" x2="11" y2="13" />
                      <polygon points="22 2 15 22 11 13 2 9 22 2" />
                    </svg>
                    Send
                  </button>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- ════ GIFT COMMANDS ════ -->
        <div id="commandsContent" class="tab-content">
          <div class="page-header">
            <div>
              <div class="page-eyebrow"><span class="eyebrow-dot"></span>Game Bridge</div>
              <h1 class="page-h1">Gift Commands</h1>
              <p class="page-sub">Map TikTok gifts to Minecraft commands.</p>
            </div>
            <div class="page-actions">
              <button class="btn-secondary btn-sm" id="socialTriggersBtn">Social Triggers</button>
              <button class="btn-primary btn-sm" id="addCommandBtn">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                  stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="5" x2="12" y2="19" />
                  <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                Add Command
              </button>
            </div>
          </div>
          <hr class="accent-rule">

          <div class="table-wrap">
            <div class="data-table-container">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>TikTok Gift</th>
                    <th>Minecraft Command</th>
                    <th style="width:100px;text-align:center;">Actions</th>
                  </tr>
                </thead>
                <tbody id="commandsTableBody">
                  <tr>
                    <td colspan="3" style="text-align:center;padding:40px;color:var(--dim);">Loading commands...</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Add/Edit Modal -->
          <div id="commandModal" class="modal-overlay" style="display:none;">
            <div class="modal-content glass">
              <h3 id="modalTitle" style="margin-bottom:22px;font-size:1.3rem;font-weight:800;">Add Command</h3>
              <div style="display:flex;flex-direction:column;gap:18px;">
                <div class="field">
                  <label class="field-label">Gift Selection</label>
                  <div style="display:flex;gap:12px;align-items:center;margin-top:6px;">
                    <div id="giftImagePreview"
                      style="width:48px;height:48px;background:var(--bg3);border-radius:var(--r-md);flex-shrink:0;display:flex;align-items:center;justify-content:center;border:1.5px solid var(--border);overflow:hidden;">
                      <span style="font-size:9px;color:var(--dim);">ICON</span>
                    </div>
                    <div style="flex:1;position:relative;">
                      <input type="text" id="giftNameInput" placeholder="Search gift..." autocomplete="off">
                      <div id="giftSearchResults" class="glass"
                        style="display:none;position:absolute;top:100%;left:0;right:0;z-index:100;margin-top:6px;max-height:50vh;overflow-y:auto;padding-bottom:10px;">
                      </div>
                    </div>
                  </div>
                </div>

                <div class="field">
                  <label class="field-label">Minecraft Commands (one per line)</label>
                  <textarea id="commandInput"
                    placeholder="execute at {playername} run summon creeper ~ ~ ~ {CustomName:'{username}', CustomNameVisible:1b}&#10;execute at {playername} run summon falling_block ~ ~10 ~ {BlockState:{Name:'minecraft:anvil'}}&#10;effect give {playername} minecraft:blindness 10 0 true"
                    rows="5" style="font-family:'JetBrains Mono',monospace;margin-top:6px;"></textarea>
                  <p style="font-size:11.5px;color:var(--dim);margin-top:6px;line-height:1.65;">
                    <span style="font-weight:700;margin-right:4px;color:var(--muted);">Placeholders:</span>
                    <code title="Randomly picked target player from your list" style="cursor:pointer;">{playername}</code> · 
                    <code title="TikTok @username of the sender" style="cursor:pointer;">{username}</code> · 
                    <code title="TikTok display name of the sender" style="cursor:pointer;">{nickname}</code> · 
                    <code title="Name of the gift" style="cursor:pointer;">{giftname}</code> · 
                    <code title="Gift count (streak total)" style="cursor:pointer;">{count}</code>
                  </p>
                </div>

                <div style="display:flex;gap:14px;">
                  <div class="field" style="flex:1;">
                    <label class="field-label">Cooldown (sec)</label>
                    <input type="number" id="cooldownInput" value="0" min="0" style="margin-top:6px;">
                  </div>
                  <div class="field" style="flex:1;justify-content:flex-end;padding-bottom:2px;">
                    <label
                      style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:600;margin-top:auto;">
                      <input type="checkbox" id="waitStreakInput" checked
                        style="width:16px;height:16px;accent-color:var(--accent);">
                      Wait for Streak End
                    </label>
                  </div>
                </div>

                <div id="delayConfigRow" style="display:none;flex-direction:column;gap:8px;">
                  <label class="field-label" style="display:flex;justify-content:space-between;">
                    <span>Execution Delay</span>
                    <span id="delayValueDisplay" style="color:var(--accent);font-weight:700;">0.2s</span>
                  </label>
                  <input type="range" id="executeDelayInput" min="0.1" max="1.0" step="0.1" value="0.2"
                    style="width:100%;accent-color:var(--accent);">
                </div>

                <div style="display:flex;gap:10px;margin-top:4px;">
                  <button class="btn-primary" id="saveCommandBtn" style="flex:2;">Save Command</button>
                  <button class="btn-secondary" id="closeModalBtn" style="flex:1;">Cancel</button>
                </div>
              </div>
            </div>
          </div>

          <!-- Delete Modal -->
          <div id="deleteConfirmModal" class="modal-overlay" style="display:none;">
            <div class="modal-content glass" style="max-width:380px;text-align:center;">
              <div style="margin-bottom:16px;">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="1.5"
                  stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                  <line x1="12" y1="9" x2="12" y2="13" />
                  <line x1="12" y1="17" x2="12.01" y2="17" />
                </svg>
              </div>
              <h3 style="margin-bottom:10px;font-size:1.2rem;font-weight:800;">Delete Command?</h3>
              <p style="color:var(--muted);margin-bottom:24px;font-size:13px;line-height:1.6;">
                Delete for <b id="deleteGiftName" style="color:var(--accent);"></b>?<br>This cannot be undone.
              </p>
              <div style="display:flex;gap:10px;">
                <button class="btn-danger" id="confirmDeleteBtn" style="flex:1;">Delete</button>
                <button class="btn-secondary" id="cancelDeleteBtn" style="flex:1;">Cancel</button>
              </div>
            </div>
          </div>

          <!-- Social Triggers Modal -->
          <div id="socialTriggersModal" class="modal-overlay" style="display:none;">
            <div class="modal-content glass">
              <h3 style="margin-bottom:20px;font-size:1.3rem;font-weight:800;">Social Triggers</h3>
              <div style="display:flex;flex-direction:column;gap:18px;">
                <div class="field">
                  <label class="field-label">Trigger: New Follow</label>
                  <textarea id="followCmdInput" placeholder="Commands for follow..." rows="3"
                    style="font-family:'JetBrains Mono',monospace;margin-top:6px;"></textarea>
                  <p style="font-size:11px;color:var(--dim);margin-top:6px;line-height:1.6;">
                    <span style="font-weight:700;margin-right:2px;color:var(--muted);">Placeholders:</span>
                    <code title="Randomly picked target player from your list" style="cursor:pointer;">{playername}</code> · 
                    <code title="TikTok @username of the sender" style="cursor:pointer;">{username}</code> · 
                    <code title="TikTok display name of the sender" style="cursor:pointer;">{nickname}</code>
                  </p>
                </div>
                <div class="field">
                  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                    <label class="field-label">Trigger: Likes Accumulated</label>
                    <div style="display:flex;align-items:center;gap:6px;">
                      <span style="font-size:12px;color:var(--dim);">Every</span>
                      <input type="number" id="likeThresholdInput" value="100"
                        style="width:80px;padding:7px 10px;text-align:center;">
                    </div>
                  </div>
                  <textarea id="likeCmdInput" placeholder="Commands for like threshold..." rows="3"
                    style="font-family:'JetBrains Mono',monospace;"></textarea>
                  <p style="font-size:11px;color:var(--dim);margin-top:6px;line-height:1.6;">
                    <span style="font-weight:700;margin-right:2px;color:var(--muted);">Placeholders:</span>
                    <code title="Randomly picked target player from your list" style="cursor:pointer;">{playername}</code> · 
                    <code title="TikTok @username of the sender" style="cursor:pointer;">{username}</code> · 
                    <code title="TikTok display name of the sender" style="cursor:pointer;">{nickname}</code>
                  </p>
                </div>
                <div style="display:flex;gap:10px;margin-top:4px;">
                  <button class="btn-primary" id="saveSocialBtn" style="flex:2;">Save Triggers</button>
                  <button class="btn-secondary" id="closeSocialBtn" style="flex:1;">Cancel</button>
                </div>
              </div>
            </div>
          </div>

        </div>
        <!-- end commandsContent -->

      </div>
      <!-- end workspace -->
    </div>
    <!-- end content-wrap -->

  </div>
  <!-- end app-layout -->
</body>

</html>