<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Admin Panel' }) %>
  <%- include('partials/admin/styles') %>
</head>
<body>
<%- include('partials/nav') %>

<%
  const diamondSvg = '<svg width="10" height="10" viewBox="0 0 640 640" fill="currentColor"><path d="M232.5 136L320 229L407.5 136L232.5 136zM447.9 163.1L375.6 240L504.6 240L448 163.1zM497.9 288L142.1 288L320 484.3L497.9 288zM135.5 240L264.5 240L192.2 163.1L135.6 240zM569.8 280.1L337.8 536.1C333.3 541.1 326.8 544 320 544C313.2 544 306.8 541.1 302.2 536.1L70.2 280.1C62.5 271.6 61.9 258.9 68.7 249.7L180.7 97.7C185.2 91.6 192.4 87.9 200 87.9L440 87.9C447.6 87.9 454.8 91.5 459.3 97.7L571.3 249.7C578.1 258.9 577.4 271.6 569.8 280.1z"/></svg>';
  const trashSvg   = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>';

  const tabLinks = [
    { id: 'gifts',    label: 'Gifts',     count: stats.gifts,     icon: '<path d="M20 12v10H4V12"/><path d="M2 7h20v5H2z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>' },
    { id: 'accounts', label: 'Accounts',  count: stats.accounts,  icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
    { id: 'donors',   label: 'Viewers',   count: stats.donors,    icon: '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>' },
    { id: 'donations',label: 'Donations', count: stats.donations,  icon: '<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>' },
    { id: 'streamers',label: 'Streamers', count: stats.streamers,  icon: '<circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0 1 12 0v2"/><circle cx="19" cy="8" r="2"/><path d="M22 20v-1a4 4 0 0 0-4-4"/>' },
    { id: 'gamedata', label: 'Game Data', count: null,             icon: '<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>' },
    { id: 'aiGifts',  label: 'AI Gifts',  count: null,             icon: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>' },
  ];

  function sortUrl(col) {
    const newDir = (sort === col && dir === 'asc') ? 'desc' : 'asc';
    return `/admin?tab=${tab}&sort=${col}&dir=${newDir}${search ? '&search=' + encodeURIComponent(search) : ''}`;
  }
  function sortIcon(col) {
    if (sort !== col) return '<svg class="sort-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>';
    return dir === 'asc'
      ? '<svg class="sort-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>'
      : '<svg class="sort-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>';
  }
%>

<div class="admin-layout">

  <aside class="admin-sidebar">
    <div class="sidebar-label">Admin Panel</div>
    <% tabLinks.forEach(t => { %>
    <a class="sidebar-link <%= tab === t.id ? 'active' : '' %>" href="/admin?tab=<%= t.id %>">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><%- t.icon %></svg>
      <%= t.label %>
      <% if (t.count !== null) { %><span class="sidebar-badge"><%= t.count %></span><% } %>
    </a>
    <% }) %>
    <div class="sidebar-divider"></div>
    <a class="sidebar-link" href="/">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Homepage
    </a>
    <a class="sidebar-link" href="/app">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
      Open App
    </a>
  </aside>

  <main class="admin-main">

    <div class="page-heading">
      <div class="page-eyebrow">Admin Panel</div>
      <h1 class="page-title">
        <% if (tab === 'gifts')     { %>Gift Database
        <% } else if (tab === 'accounts')  { %>User Accounts
        <% } else if (tab === 'donors')    { %>TikTok Viewers
        <% } else if (tab === 'donations') { %>Donation History
        <% } else if (tab === 'streamers') { %>Streamers
        <% } else if (tab === 'aiGifts')   { %>AI Preferred Gifts
        <% } else { %>Game Data<% } %>
      </h1>
    </div>

    <div class="stats-grid">
      <div class="stat-card teal"><div class="stat-label">Accounts</div><div class="stat-value"><%= stats.accounts %></div></div>
      <div class="stat-card"><div class="stat-label">Gifts</div><div class="stat-value"><%= stats.gifts %></div></div>
      <div class="stat-card"><div class="stat-label">Donations</div><div class="stat-value"><%= stats.donations %></div></div>
      <div class="stat-card"><div class="stat-label">Viewers</div><div class="stat-value"><%= stats.donors %></div></div>
      <div class="stat-card"><div class="stat-label">Streamers</div><div class="stat-value"><%= stats.streamers %></div></div>
      <div class="stat-card"><div class="stat-label">Isaac Items</div><div class="stat-value"><%= stats.isaacItems %></div></div>
      <div class="stat-card"><div class="stat-label">Isaac Bosses</div><div class="stat-value"><%= stats.isaacBosses %></div></div>
      <div class="stat-card"><div class="stat-label">Repo Items</div><div class="stat-value"><%= stats.repoItems + stats.repoValuables + stats.repoEnemies %></div></div>
    </div>

    <% if (success) { %>
    <div class="alert alert-success">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      <%= success %>
    </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <%= error %>
    </div>
    <% } %>

    <% if (tab === 'gifts')          { %><%- include('partials/admin/tab-gifts',     { sortUrl, sortIcon, diamondSvg, trashSvg }) %>
    <% } else if (tab === 'accounts')  { %><%- include('partials/admin/tab-accounts', { sortUrl, sortIcon, trashSvg }) %>
    <% } else if (tab === 'donors')    { %><%- include('partials/admin/tab-donors',   { sortUrl, sortIcon, diamondSvg }) %>
    <% } else if (tab === 'donations') { %><%- include('partials/admin/tab-donations',{ sortUrl, sortIcon, diamondSvg }) %>
    <% } else if (tab === 'streamers') { %><%- include('partials/admin/tab-streamers',{ sortUrl, sortIcon, diamondSvg }) %>
    <% } else if (tab === 'aiGifts')   { %><%- include('partials/admin/tab-ai-gifts', { diamondSvg, trashSvg }) %>
    <% } else                          { %><%- include('partials/admin/tab-gamedata') %>
    <% } %>

  </main>
</div>

<%- include('partials/admin/delete-modal') %>
</body>
</html>
