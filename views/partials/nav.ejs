<style>
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px; height: 62px;
    background: rgba(6,9,18,0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(0,242,234,0.1);
    font-family: 'Inter', system-ui, sans-serif;
  }
  nav .logo {
    font-size: 22px; font-weight: 800; letter-spacing: -0.5px;
    color: #e8eaf0; text-decoration: none;
  }
  nav .logo span { color: #00f2ea; }
  .nav-right { display: flex; gap: 12px; align-items: center; height: 100%; }

  .nav-btn {
    display: inline-flex; align-items: center; gap: 7px;
    text-decoration: none; padding: 8px 20px; border-radius: 8px;
    font-size: 13px; font-weight: 600; cursor: pointer;
    transition: all 0.18s; border: none; font-family: inherit;
    background: none;
  }
  .nav-btn-ghost {
    border: 1px solid rgba(0,242,234,0.1); color: #5a6385;
  }
  .nav-btn-ghost:hover { border-color: #00f2ea; color: #00f2ea; }
  .nav-btn-teal {
    background: #00f2ea; color: #060912;
    border: none;
    box-shadow: 0 0 18px rgba(0,242,234,0.28);
  }
  .nav-btn-teal:hover { background: #00fff5; box-shadow: 0 0 28px rgba(0,242,234,0.45); }

  /* Avatar */
  .nav-avatar-wrap { position: relative; display: flex; align-items: center; }
  .nav-avatar-btn {
    width: 36px; height: 36px; border-radius: 50%;
    border: 2px solid rgba(0,242,234,0.2);
    background: rgba(0,242,234,0.08);
    cursor: pointer; padding: 0; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    transition: border-color 0.18s, box-shadow 0.18s;
  }
  .nav-avatar-btn:hover {
    border-color: #00f2ea;
    box-shadow: 0 0 0 3px rgba(0,242,234,0.12);
  }
  .nav-avatar-img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
  .nav-avatar-initials { font-size: 14px; font-weight: 800; color: #00f2ea; text-transform: uppercase; line-height: 1; }

  /* Dropdown */
  .nav-dropdown {
    position: absolute; top: calc(100% + 10px);
    left: 50%; transform: translateX(-50%) translateY(-8px) scale(0.97);
    background: #0c1220;
    border: 1px solid rgba(0,242,234,0.1);
    border-radius: 14px;
    min-width: 220px;
    box-shadow: 0 20px 48px rgba(0,0,0,0.6);
    opacity: 0; pointer-events: none;
    transition: opacity 0.15s, transform 0.15s;
    z-index: 200; overflow: hidden;
  }
  .nav-dropdown.open {
    opacity: 1; pointer-events: all;
    transform: translateX(-50%) translateY(0) scale(1);
  }
  .nav-dropdown-header { padding: 14px 16px 12px; }
  .nav-dropdown-name { font-size: 13px; font-weight: 800; color: #e8eaf0; margin-bottom: 3px; }
  .nav-dropdown-email { font-size: 11px; color: #404d65; }
  .nav-dropdown-divider { height: 1px; background: rgba(255,255,255,0.05); }
  .nav-dropdown-item {
    display: flex; align-items: center; gap: 10px;
    padding: 11px 16px;
    font-size: 13px; font-weight: 600; color: #5a6385;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .nav-dropdown-item:hover { background: rgba(255,255,255,0.04); color: #e8eaf0; }
  .nav-dropdown-danger { color: #f43f5e !important; }
  .nav-dropdown-danger:hover { background: rgba(244,63,94,0.07) !important; }

  @media (max-width: 600px) {
    nav { padding: 0 20px; }
  }
</style>

<nav>
  <a class="logo" href="/">Triny<span>Tok</span></a>
  <div class="nav-right">
    <% if (user) { %>
      <div class="nav-avatar-wrap">
        <button class="nav-avatar-btn" id="navAvatarBtn" aria-label="Account menu">
          <img src="https://unavatar.io/tiktok/<%= user.username %>" alt="<%= user.username %>" class="nav-avatar-img" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
          <span class="nav-avatar-initials" style="display:none;"><%= user.username.charAt(0).toUpperCase() %></span>
        </button>
        <div class="nav-dropdown" id="navDropdown">
          <div class="nav-dropdown-header">
            <div class="nav-dropdown-name">@<%= user.username %></div>
            <div class="nav-dropdown-email"><%= user.email %></div>
          </div>
          <div class="nav-dropdown-divider"></div>
          <a class="nav-dropdown-item" href="/account">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            My Account
          </a>
          <div class="nav-dropdown-divider"></div>
          <a class="nav-dropdown-item nav-dropdown-danger" href="/logout">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sign out
          </a>
        </div>
      </div>
      <a class="nav-btn nav-btn-teal" href="/app">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
        Open App
      </a>
    <% } else { %>
      <a class="nav-btn nav-btn-ghost" href="/login">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        Log in
      </a>
      <a class="nav-btn nav-btn-teal" href="/register">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
        Sign up
      </a>
    <% } %>
  </div>
</nav>

<script>
  (function() {
    const btn = document.getElementById('navAvatarBtn');
    const dropdown = document.getElementById('navDropdown');
    if (!btn) return;

    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      dropdown.classList.toggle('open');
    });
    document.addEventListener('click', function() {
      dropdown.classList.remove('open');
    });

  })();
</script>
