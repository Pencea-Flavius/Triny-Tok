<p style="font-size:13px;color:rgba(255,255,255,0.4);margin-bottom:20px;line-height:1.6;">
  Gifts in this list are used by the AI preset generator as a secondary priority — after real viewer donations, before random fallback. Add gifts you commonly see viewers send.
</p>

<form method="POST" action="/admin/ai-gifts/add" style="display:flex;gap:10px;align-items:flex-end;margin-bottom:24px;flex-wrap:wrap;">
  <div style="flex:1;min-width:220px;">
    <label style="display:block;font-size:10px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:6px;">Gift Name</label>
    <div style="position:relative;">
      <input id="aiGiftInput" name="giftName" class="search-input" type="text" placeholder="Type to search gifts..." autocomplete="off" style="width:100%;">
      <div id="aiGiftDropdown" style="display:none;position:absolute;top:calc(100% + 4px);left:0;right:0;z-index:100;background:#0c1220;border:1px solid rgba(255,255,255,0.1);border-radius:10px;overflow:hidden;max-height:240px;overflow-y:auto;"></div>
    </div>
  </div>
  <button type="submit" class="btn-search" style="height:38px;">Add Gift</button>
</form>

<div style="font-size:12px;color:rgba(255,255,255,0.3);margin-bottom:12px;"><%= aiPreferredGifts.length %> preferred gift<%= aiPreferredGifts.length !== 1 ? 's' : '' %></div>

<% if (aiPreferredGifts.length === 0) { %>
<div class="empty-state">No preferred gifts yet. Add gifts above to help the AI make better presets.</div>
<% } else { %>
<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th style="width:44px;"></th>
        <th>Gift Name</th>
        <th>Diamonds</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% aiPreferredGifts.forEach(g => { %>
      <%
        const catalogEntry = allGifts.find(ag => ag.name.trim() === g.name.trim());
        const imgUrl   = catalogEntry?.imageUrl || null;
        const diamonds = catalogEntry ? (catalogEntry.diamond_count || 0) : g.diamond_count;
      %>
      <tr>
        <td><% if (imgUrl) { %><img src="<%= imgUrl %>" class="gift-img" alt=""><% } %></td>
        <td><strong style="color:#e8eaf0;"><%= g.name %></strong></td>
        <td><span class="diamonds"><%- diamondSvg %> <%= diamonds %></span></td>
        <td>
          <div class="action-group">
            <form method="POST" action="/admin/ai-gifts/<%= g.id %>/delete" style="margin:0;">
              <button type="submit" class="btn-sm btn-danger-sm"><%- trashSvg %> Remove</button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<script>
(function() {
  const allGifts = <%- JSON.stringify(allGifts.map(g => ({ name: g.name, diamonds: g.diamond_count || 0, imageUrl: g.imageUrl || null }))) %>;
  const input    = document.getElementById('aiGiftInput');
  const dropdown = document.getElementById('aiGiftDropdown');

  function renderDropdown(query) {
    const q = (query || '').toLowerCase().trim();
    const matches = allGifts.filter(g => g.name.toLowerCase().includes(q)).sort((a, b) => a.diamonds - b.diamonds).slice(0, 20);
    if (!matches.length) { dropdown.style.display = 'none'; return; }
    dropdown.innerHTML = matches.map(g => `
      <div class="ai-gift-option" data-name="${g.name.replace(/"/g,'&quot;')}" style="display:flex;align-items:center;gap:10px;padding:8px 14px;cursor:pointer;font-size:13px;color:#c8cad8;transition:background 0.1s;">
        ${g.imageUrl ? `<img src="${g.imageUrl}" style="width:24px;height:24px;object-fit:contain;border-radius:4px;flex-shrink:0;">` : '<div style="width:24px;height:24px;border-radius:4px;background:rgba(255,255,255,0.05);flex-shrink:0;"></div>'}
        <span style="flex:1;">${g.name}</span>
        <span style="color:#00f2ea;font-size:11px;font-weight:700;display:inline-flex;align-items:center;gap:3px;"><svg width="9" height="9" viewBox="0 0 640 640" fill="currentColor"><path d="M232.5 136L320 229L407.5 136L232.5 136zM447.9 163.1L375.6 240L504.6 240L448 163.1zM497.9 288L142.1 288L320 484.3L497.9 288zM135.5 240L264.5 240L192.2 163.1L135.6 240zM569.8 280.1L337.8 536.1C333.3 541.1 326.8 544 320 544C313.2 544 306.8 541.1 302.2 536.1L70.2 280.1C62.5 271.6 61.9 258.9 68.7 249.7L180.7 97.7C185.2 91.6 192.4 87.9 200 87.9L440 87.9C447.6 87.9 454.8 91.5 459.3 97.7L571.3 249.7C578.1 258.9 577.4 271.6 569.8 280.1z"/></svg> ${g.diamonds}</span>
      </div>
    `).join('');
    dropdown.querySelectorAll('.ai-gift-option').forEach(el => {
      el.addEventListener('mouseenter', () => el.style.background = 'rgba(255,255,255,0.05)');
      el.addEventListener('mouseleave', () => el.style.background = '');
      el.addEventListener('mousedown',  e => { e.preventDefault(); input.value = el.dataset.name; dropdown.style.display = 'none'; });
    });
    dropdown.style.display = 'block';
  }

  input.addEventListener('input', () => renderDropdown(input.value));
  input.addEventListener('focus', () => { if (input.value) renderDropdown(input.value); });
  document.addEventListener('click', e => { if (!input.contains(e.target) && !dropdown.contains(e.target)) dropdown.style.display = 'none'; });
})();
</script>
