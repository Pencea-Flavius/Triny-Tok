<div class="modal-overlay" id="deleteModal">
  <div class="modal-box">
    <div class="modal-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
        <path d="M10 11v6"/><path d="M14 11v6"/>
      </svg>
    </div>
    <div class="modal-title" id="modalTitle">Delete?</div>
    <div class="modal-desc"  id="modalDesc"></div>
    <div class="modal-actions">
      <button class="btn-modal-cancel" id="modalCancel">Cancel</button>
      <form id="modalForm" method="POST" style="margin:0;">
        <button type="submit" class="btn-modal-confirm">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
          Yes, delete
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  const modal      = document.getElementById('deleteModal');
  const modalForm  = document.getElementById('modalForm');
  const modalTitle = document.getElementById('modalTitle');
  const modalDesc  = document.getElementById('modalDesc');

  function openModal(type, id, name) {
    if (type === 'gift') {
      modalTitle.textContent = 'Delete gift?';
      modalDesc.innerHTML    = `Remove <strong style="color:#e8eaf0;">${name}</strong> from the database? This cannot be undone.`;
      modalForm.action       = `/admin/gifts/${id}/delete?tab=gifts&<%= sort ? 'sort=' + sort + '&dir=' + dir + '&' : '' %><%= search ? 'search=' + encodeURIComponent(search) : '' %>`;
    } else {
      modalTitle.textContent = 'Delete account?';
      modalDesc.innerHTML    = `Permanently delete <strong style="color:#e8eaf0;">@${name}</strong>? This cannot be undone.`;
      modalForm.action       = `/admin/accounts/${id}/delete`;
    }
    modal.classList.add('open');
  }

  document.getElementById('modalCancel').addEventListener('click', () => modal.classList.remove('open'));
  modal.addEventListener('click', e => { if (e.target === modal) modal.classList.remove('open'); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') modal.classList.remove('open'); });
</script>
