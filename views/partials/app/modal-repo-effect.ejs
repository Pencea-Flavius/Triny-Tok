<!-- REPO Effect Modal -->
<div id="repoEffectModal" class="modal-overlay" style="display:none;">
  <div class="modal-content glass" style="max-width:600px;width:100%;">
    <h3 id="repoModalTitle" style="margin-bottom:18px;font-size:1.2rem;font-weight:800;letter-spacing:-.02em;">Add R.E.P.O. Effect</h3>
    <div style="display:flex;flex-direction:column;gap:14px;">

      <!-- Gift Selector -->
      <%- include('../gift-selector', { previewId: 'repoGiftImagePreview', inputId: 'repoGiftInput', resultsId: 'repoGiftResults' }) %>

      <!-- Category filter tabs -->
      <div style="display:flex;gap:4px;flex-wrap:wrap;" id="repoCategoryTabs"></div>

      <!-- Effects grid -->
      <div id="repoEffectCards" style="display:grid;grid-template-columns:1fr 1fr;gap:6px;max-height:280px;overflow-y:auto;padding:2px;border:1px solid var(--border);border-radius:8px;background:var(--bg3);padding:8px;"></div>

      <!-- Duration (shown for timed effects) -->
      <div id="repoDurationRow" style="display:none;padding:10px 14px;background:var(--bg4);border:1px solid var(--border2);border-radius:var(--r-md);">
        <label class="field-label" style="margin-bottom:6px;display:block;">Duration (seconds)</label>
        <input type="number" id="repoEffectDuration" class="input-base" min="1" max="300" value="10" style="width:100%;">
        <div style="font-size:0.68rem;color:var(--dim);margin-top:4px;">How long the timed effect lasts on the player</div>
      </div>

      <!-- Wait for streak and random -->
      <div style="margin-top:4px;padding-top:12px;border-top:1px solid var(--border);display:flex;flex-direction:row;justify-content:space-between;align-items:center;">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:600;">
          <input type="checkbox" id="repoTargetRandom" style="width:16px;height:16px;accent-color:var(--accent);">
          Target Random Player
        </label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:600;">
          <input type="checkbox" id="repoWaitStreak" checked style="width:16px;height:16px;accent-color:var(--accent);">
          Wait for Streak End
        </label>
      </div>

      <!-- Save/Cancel -->
      <div style="display:flex;gap:10px;margin-top:2px;">
        <button class="btn-primary" id="saveRepoEffectBtn" style="flex:2;">Save Effect</button>
        <button class="btn-secondary" id="cancelRepoModalBtn" style="flex:1;">Cancel</button>
      </div>
    </div>
  </div>
</div>
