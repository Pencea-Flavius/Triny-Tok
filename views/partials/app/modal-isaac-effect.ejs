<!-- Isaac Effect Modal -->
<div id="isaacEffectModal" class="modal-overlay" style="display:none;">
  <div class="modal-content glass" style="max-width:580px;width:100%;">
    <h3 id="isaacModalTitle" style="margin-bottom:18px;font-size:1.2rem;font-weight:800;letter-spacing:-.02em;">Add TBOI
      Effect</h3>
    <div style="display:flex;flex-direction:column;gap:14px;">

      <!-- Gift Selector -->
      <%- include('../gift-selector', { previewId: 'isaacGiftImagePreview' , inputId: 'isaacGiftInput' ,
        resultsId: 'isaacGiftResults' }) %>

        <!-- Mode Toggle -->
        <div
          style="display:grid;grid-template-columns:1fr 1fr;gap:4px;background:rgba(0,0,0,0.25);padding:4px;border-radius:10px;border:1px solid var(--border);">
          <button id="isaacModeCustomBtn" class="isaac-mode-btn active" onclick="">Custom Action</button>
          <button id="isaacModeProfileBtn" class="isaac-mode-btn" onclick="">Preset Effects</button>
        </div>

        <!-- Custom Action Panel -->
        <div id="isaacCustomActionView" style="display:flex;flex-direction:column;gap:12px;">

          <!-- Action Type tabs -->
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px;">
            <button class="isaac-action-tab active" data-action="spawn_item">
              <img src="/images/Isaac/item.png"
                style="width:48px;height:48px;object-fit:contain;image-rendering:pixelated;transition:transform 0.2s ease;">
              <span>Items</span>
            </button>
            <button class="isaac-action-tab" data-action="spawn_boss">
              <img src="/images/Isaac/boss.png"
                style="width:48px;height:48px;object-fit:contain;image-rendering:pixelated;transition:transform 0.2s ease;">
              <span>Bosses</span>
            </button>
            <button class="isaac-action-tab" data-action="spawn_entity">
              <img src="/images/Isaac/summon.png"
                style="width:48px;height:48px;object-fit:contain;image-rendering:pixelated;transition:transform 0.2s ease;">
              <span>Summon</span>
            </button>
          </div>

          <!-- spawn_item fields -->
          <div class="isaac-action-fields" id="fields_spawn_item">
            <div style="display:flex;flex-direction:column;gap:8px;">
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <label class="field-label">Search Item</label>
              </div>
              <div style="position:relative;">
                <div
                  style="display:flex;align-items:center;gap:10px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:8px 12px;transition:border-color .15s;"
                  id="isaacItemSearchWrapper">
                  <div id="isaacItemPreview"
                    style="width:48px;height:48px;border-radius:6px;background:var(--bg2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;">
                    <span style="font-size:9px;color:var(--text-muted);">ITEM</span>
                  </div>
                  <div style="flex:1;">
                    <input type="text" id="isaacItemSearchInput" class="input-ghost"
                      placeholder="Search items... (e.g. Magic Mushroom, Mom's Knife)"
                      style="width:100%;background:none;border:none;outline:none;color:var(--text);font-size:.9rem;"
                      autocomplete="off">
                    <div id="isaacItemNameLabel"
                      style="font-size:.7rem;color:var(--text-muted);margin-top:1px;display:none;"></div>
                  </div>
                  <div id="isaacItemQualityBadge"
                    style="display:none;padding:2px 8px;border-radius:4px;font-size:.7rem;font-weight:700;white-space:nowrap;">
                  </div>
                </div>
                <div id="isaacItemSearchResults" class="glass search-results-list" style="display:none;"></div>
              </div>

              <!-- Filters -->
              <div style="display:flex; gap:6px; margin-top:8px;">
                <select id="isaacFilterQuality" class="input-base" style="flex:1; min-width:0;">
                  <option value="">All Q</option>
                  <option value="0">Q0</option>
                  <option value="1">Q1</option>
                  <option value="2">Q2</option>
                  <option value="3">Q3</option>
                  <option value="4">Q4</option>
                </select>
                <select id="isaacFilterType" class="input-base" style="flex:1.2; min-width:0;">
                  <option value="">All Types</option>
                </select>
                <select id="isaacFilterPool" class="input-base" style="flex:2; min-width:0;">
                  <option value="">All Pools</option>
                </select>
              </div>

              <input type="hidden" id="isaacSelectedItemId">
            </div>
            <!-- use_item toggle — shown only for Active items -->
            <div id="isaacUseEffectRow"
              style="display:none;margin-top:10px;padding:8px 12px;background:var(--bg4);border:1px solid var(--border2);border-radius:var(--r-md);">
              <label
                style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:0.75rem;color:var(--accent);font-weight:800;text-transform:uppercase;letter-spacing:0.5px;">
                <input type="checkbox" id="isaacUseEffectOnly"
                  style="width:16px;height:16px;accent-color:var(--accent);margin:0;">
                Use Effect Only
              </label>
              <div style="font-size:0.68rem;color:var(--dim);margin-top:4px;margin-left:24px;">Triggers the active
                item's effect without adding it to inventory</div>
            </div>

            <div id="isaacItemSpawnOptions" style="margin-top:12px; display:flex; align-items:flex-end; gap:20px;">
              <div style="flex:1;">
                <label class="field-label">Amount</label>
                <input type="number" min="1" max="99" class="input-base" id="isaacItemAmountInput" value="1"
                  style="width:100%;">
              </div>
              <div style="flex:2; padding-bottom:10px;">
                <label
                  style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:0.75rem;color:var(--dim);font-weight:800;text-transform:uppercase;letter-spacing:0.5px;">
                  <input type="checkbox" id="isaacItemAutoCollect"
                    style="width:16px;height:16px;accent-color:var(--accent);margin:0;">
                  Auto-Collect
                </label>
              </div>
            </div>
          </div>

          <!-- spawn_boss fields -->
          <div class="isaac-action-fields" id="fields_spawn_boss" style="display:none;">
            <div style="display:flex;flex-direction:column;gap:8px;">
              <label class="field-label">Search Boss</label>
              <div style="position:relative;">
                <div
                  style="display:flex;align-items:center;gap:10px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:8px 12px;transition:border-color .15s;"
                  id="isaacBossSearchWrapper">
                  <div id="isaacBossPreview"
                    style="width:48px;height:48px;border-radius:6px;background:var(--bg2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;">
                    <span style="font-size:9px;color:var(--text-muted);">BOSS</span>
                  </div>
                  <div style="flex:1;">
                    <input type="text" id="isaacBossSearchInput" class="input-ghost"
                      placeholder="Search bosses... (e.g. Monstro, Isaac)"
                      style="width:100%;background:none;border:none;outline:none;color:var(--text);font-size:.9rem;"
                      autocomplete="off">
                    <div id="isaacBossNameLabel"
                      style="font-size:.7rem;color:var(--text-muted);margin-top:1px;display:none;"></div>
                  </div>
                </div>
                <div id="isaacBossSearchResults" class="glass search-results-list" style="display:none;"></div>
              </div>

              <div style="margin-top:12px; display:flex; align-items:flex-end; gap:20px;">
                <div style="flex:1;">
                  <label class="field-label">Amount</label>
                  <input type="number" min="1" max="10" class="input-base" id="isaacBossAmountInput" value="1"
                    style="width:100%;">
                </div>
                <div style="flex:2;">
                  <div id="isaacBossHpInfo" style="font-size:0.7rem;color:var(--dim);margin-bottom:4px;display:none;">
                    Base HP: <span id="isaacBossBaseHp" style="color:var(--text);font-weight:700;">-</span>
                  </div>
                </div>
              </div>
              <div id="isaacBossSegmentHint" style="display:none;margin-top:8px;padding:8px 12px;background:rgba(251,191,36,0.08);border:1px solid rgba(251,191,36,0.3);border-radius:8px;font-size:0.75rem;color:#fbbf24;font-weight:600;"></div>
              <input type="hidden" id="isaacSelectedBossId">
            </div>
          </div>

          <!-- spawn_entity fields (Summon) -->
          <div class="isaac-action-fields" id="fields_spawn_entity" style="display:none;">
            <div style="display:flex;gap:10px;">
              <div style="flex:2;">
                <label class="field-label">Isaac Entity ID</label>
                <input type="text" class="input-base" id="isaacEntityIdInput" placeholder="e.g. 5.10.0">
              </div>
              <div style="flex:1;">
                <label class="field-label">Amount</label>
                <input type="number" min="1" max="99" class="input-base" id="isaacEntityAmountInput" value="1">
              </div>
            </div>
            <div
              style="margin-top:8px;padding:10px 12px;background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:8px;font-size:.78rem;color:var(--text-muted);">
              Input a valid entity ID from The Binding of Isaac.
            </div>
          </div>
        </div>

        <!-- Presets Panel -->
        <div id="isaacProfileView" style="display:none;">
          <label class="field-label" style="margin-bottom:8px;display:block;">Select Profile</label>
          <div id="isaacEffectCards"
            style="display:grid;grid-template-columns:1fr 1fr;gap:8px;max-height:240px;overflow-y:auto;padding:2px;">
          </div>
        </div>

        <!-- Global Settings -->
        <div
          style="margin-top:4px; padding-top:12px; border-top:1px solid var(--border); display:flex; justify-content:flex-end;">
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:600;">
            <input type="checkbox" id="isaacWaitStreak" checked
              style="width:16px;height:16px;accent-color:var(--accent);">
            Wait for Streak End
          </label>
        </div>

        <!-- Save/Cancel -->
        <div style="display:flex;gap:10px;margin-top:2px;">
          <button class="btn-primary" id="saveIsaacEffectBtn" style="flex:2;">Save Effect</button>
          <button class="btn-secondary" id="cancelIsaacModalBtn" style="flex:1;">Cancel</button>
        </div>
    </div>
  </div>
</div>