<!-- GOI Setup Guide Modal -->
<div id="goiSetupModal" class="modal-overlay" style="display:none;">
  <div class="modal-content glass" style="max-width:550px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
      <h3 style="font-size:1.3rem;font-weight:800;margin:0;">Getting Over It Mod Setup</h3>
      <button class="btn-secondary btn-sm" id="closeGoiSetupBtn" style="padding:4px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>

    <div style="display:flex;flex-direction:column;gap:16px;font-size:0.95rem;line-height:1.6;">
      <div class="card-tip" style="background:rgba(52,152,219,0.1);border-left-color:var(--accent);">
        <div class="tip-icon" style="color:var(--accent);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        </div>
        <div>
          <div class="tip-title">Requirements</div>
          <div class="tip-desc">You need <b>Getting Over It with Bennett Foddy</b> installed via Steam and the zip below contains everything else needed (MelonLoader + mod).</div>
        </div>
      </div>

      <div style="background:var(--bg3);padding:15px;border-radius:10px;border:1px solid var(--border);">
        <div style="font-weight:700;margin-bottom:8px;font-size:0.8rem;text-transform:uppercase;color:var(--dim);">Step 1: Download & Extract Mod</div>
        <div style="display:flex; gap:12px; align-items:center; margin-bottom:12px;">
          <a href="/downloads/trinytokgoi.zip" class="btn-primary btn-sm" style="text-decoration:none; display:flex; align-items:center; gap:6px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            Download Mod
          </a>
          <span style="font-size:0.8rem; color:var(--muted);">v1.0.1</span>
        </div>
        <p style="margin-bottom:10px;">Extract the zip <b>directly into your Getting Over It game folder</b> (merge/overwrite when asked).</p>
        <p style="font-size:0.85rem;color:var(--muted);">Find the game folder by right-clicking <b>Getting Over It</b> in Steam → <b>Manage</b> → <b>Browse local files</b>.</p>
      </div>

      <div style="background:var(--bg3);padding:15px;border-radius:10px;border:1px solid var(--border);">
        <div style="font-weight:700;margin-bottom:8px;font-size:0.8rem;text-transform:uppercase;color:var(--dim);">Step 2: Connect</div>
        <p>Click <b>Start Bridge</b> in this dashboard, then launch Getting Over It. Once in a game the status will turn <b style="color:var(--success);">GREEN</b>.</p>
      </div>

      <button class="btn-primary" id="goiGotItBtn" style="margin-top:10px;">Got it, let's play!</button>
    </div>
  </div>
</div>
