<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Create Account' }) %>
  <link rel="stylesheet" href="/css/login.css">
</head>
<body>

<%- include('partials/nav') %>

<div class="login-wrap">
  <div class="glow-blob blob-a"></div>
  <div class="glow-blob blob-b"></div>

  <div class="login-container">

    <div class="login-card">
      <a href="/" style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:var(--dim);text-decoration:none;margin-bottom:20px;transition:color 0.15s;" onmouseover="this.style.color='var(--teal)'" onmouseout="this.style.color='var(--dim)'">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Back to homepage
      </a>
      <div class="login-header">
        <div class="login-logo">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <line x1="19" y1="8" x2="19" y2="14"/>
            <line x1="22" y1="11" x2="16" y2="11"/>
          </svg>
        </div>
        <h1 class="login-title">Create account</h1>
        <p class="login-sub">Join TrinyTok to manage your streams and game integrations.</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
      <div class="login-error" style="display:flex; margin-bottom:4px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <span><%= error %></span>
      </div>
      <% } %>

      <form class="login-form" method="POST" action="/register" id="registerForm">

        <div class="form-row-2">
          <div class="form-field">
            <label class="form-label" for="firstName">First Name</label>
            <input type="text" id="firstName" name="firstName"
              value="<%= typeof values !== 'undefined' ? values.firstName || '' : '' %>"
              placeholder="John" required autocomplete="given-name">
          </div>
          <div class="form-field">
            <label class="form-label" for="lastName">Last Name</label>
            <input type="text" id="lastName" name="lastName"
              value="<%= typeof values !== 'undefined' ? values.lastName || '' : '' %>"
              placeholder="Doe" required autocomplete="family-name">
          </div>
        </div>

        <div class="form-field">
          <label class="form-label" for="username">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
            TikTok Username
          </label>
          <input type="text" id="username" name="username"
            value="<%= typeof values !== 'undefined' ? values.username || '' : '' %>"
            placeholder="your_tiktok_handle" required autocomplete="username"
            pattern="[a-zA-Z0-9_.]{3,30}" title="3–30 characters: letters, numbers, underscores">
          <span style="font-size:11px; color:var(--dim); margin-top:2px;">Use your exact TikTok handle — this is used to connect to your live stream.</span>
        </div>

        <div class="form-field">
          <label class="form-label" for="email">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
            Email Address
          </label>
          <input type="email" id="email" name="email"
            value="<%= typeof values !== 'undefined' ? values.email || '' : '' %>"
            placeholder="you@example.com" required autocomplete="email">
        </div>

        <div class="form-row-2">
          <div class="form-field">
            <label class="form-label" for="password">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
              Password
            </label>
            <div class="password-wrap">
              <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="new-password" minlength="8">
              <button type="button" class="toggle-pw" id="togglePassword" aria-label="Toggle password visibility">
                <svg class="eye-open" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                </svg>
                <svg class="eye-closed" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                  <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                  <line x1="1" y1="1" x2="23" y2="23"/>
                </svg>
              </button>
            </div>
          </div>
          <div class="form-field">
            <label class="form-label" for="password2">Confirm Password</label>
            <input type="password" id="password2" name="password2" placeholder="••••••••" required autocomplete="new-password" minlength="8">
          </div>
        </div>

        <div class="form-field">
          <label class="form-label" for="birthDate">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Date of Birth
          </label>
          <input type="date" id="birthDate" name="birthDate"
            value="<%= typeof values !== 'undefined' ? values.birthDate || '' : '' %>"
            required>
        </div>

        <div class="ai-prefs-box">
          <div class="ai-prefs-header">
            <div class="ai-prefs-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2z"/>
              </svg>
            </div>
            <div>
              <div class="ai-prefs-title">AI Streaming Preferences</div>
              <div class="ai-prefs-sub">Optional — helps the AI suggest better games and presets for you.</div>
            </div>
          </div>

          <div class="pref-group">
            <div class="pref-group-label">Favorite Games</div>
            <div class="pref-chips">
              <label class="pref-chip"><input type="checkbox" name="favoriteGames" value="minecraft"><span>Minecraft</span></label>
              <label class="pref-chip"><input type="checkbox" name="favoriteGames" value="isaac"><span>Isaac</span></label>
              <label class="pref-chip"><input type="checkbox" name="favoriteGames" value="repo"><span>R.E.P.O.</span></label>
              <label class="pref-chip"><input type="checkbox" name="favoriteGames" value="goi"><span>Getting Over It</span></label>
              <label class="pref-chip"><input type="checkbox" name="favoriteGames" value="other"><span>Other</span></label>
            </div>
          </div>

          <div class="pref-group">
            <div class="pref-group-label">Streaming Style</div>
            <div class="pref-chips">
              <label class="pref-chip"><input type="checkbox" name="streamingGenre" value="troll"><span>Troll</span></label>
              <label class="pref-chip"><input type="checkbox" name="streamingGenre" value="competitive"><span>Competitive</span></label>
              <label class="pref-chip"><input type="checkbox" name="streamingGenre" value="educational"><span>Educational</span></label>
              <label class="pref-chip"><input type="checkbox" name="streamingGenre" value="chill"><span>Chill</span></label>
            </div>
          </div>

          <div class="pref-group">
            <div class="pref-group-label">Target Audience</div>
            <div class="pref-chips">
              <label class="pref-chip"><input type="checkbox" name="targetAudience" value="kids"><span>Kids</span></label>
              <label class="pref-chip"><input type="checkbox" name="targetAudience" value="adults"><span>Adults</span></label>
              <label class="pref-chip"><input type="checkbox" name="targetAudience" value="core_gamers"><span>Core Gamers</span></label>
              <label class="pref-chip"><input type="checkbox" name="targetAudience" value="casual"><span>Casual</span></label>
            </div>
          </div>

          <div class="pref-group">
            <div class="pref-group-label">Streaming Schedule</div>
            <div class="pref-chips">
              <label class="pref-chip"><input type="checkbox" name="streamingSchedule" value="morning"><span>Morning</span></label>
              <label class="pref-chip"><input type="checkbox" name="streamingSchedule" value="evening"><span>Evening</span></label>
              <label class="pref-chip"><input type="checkbox" name="streamingSchedule" value="weekend"><span>Weekend</span></label>
            </div>
          </div>

          <div class="pref-group" style="margin-bottom:0;">
            <div class="pref-group-label">Game Genres</div>
            <div class="pref-chips">
              <label class="pref-chip"><input type="checkbox" name="gameGenres" value="fps"><span>FPS</span></label>
              <label class="pref-chip"><input type="checkbox" name="gameGenres" value="rpg"><span>RPG</span></label>
              <label class="pref-chip"><input type="checkbox" name="gameGenres" value="survival"><span>Survival</span></label>
              <label class="pref-chip"><input type="checkbox" name="gameGenres" value="platformer"><span>Platformer</span></label>
              <label class="pref-chip"><input type="checkbox" name="gameGenres" value="horror"><span>Horror</span></label>
            </div>
          </div>
        </div>

        <button type="submit" class="btn-login" id="registerBtn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
            <line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
          </svg>
          Create Account
        </button>

      </form>

      <div class="login-footer-text" style="margin-top:24px;">
        Already have an account? <a href="/login" class="signup-link">Sign in</a>
      </div>
    </div>

    <div class="login-features">
      <div style="margin-bottom:8px;">
        <div style="font-size:11px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--teal);margin-bottom:12px;">What you get</div>
        <h2 style="font-size:26px;font-weight:900;letter-spacing:-0.8px;margin-bottom:10px;">Everything your stream needs</h2>
        <p style="font-size:14px;color:var(--muted);line-height:1.7;">Connect your TikTok LIVE stream to your games. Gifts trigger real in-game events — all running locally on your machine.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
        </div>
        <div>
          <div class="feature-title">Real-Time Events</div>
          <div class="feature-desc">Gifts trigger in-game events instantly — zero latency, pure chaos.</div>
        </div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <div>
          <div class="feature-title">Multi-Game Support</div>
          <div class="feature-desc">Minecraft, Isaac, Terraria, Repo — and more coming soon.</div>
        </div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <div>
          <div class="feature-title">Runs Locally</div>
          <div class="feature-desc">Your data stays on your machine. No cloud, no tracking, no limits.</div>
        </div>
      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>

<script>
  const toggleBtn = document.getElementById('togglePassword');
  const pwInput = document.getElementById('password');
  const pw2Input = document.getElementById('password2');
  const eyeOpen = toggleBtn.querySelector('.eye-open');
  const eyeClosed = toggleBtn.querySelector('.eye-closed');

  toggleBtn.addEventListener('click', () => {
    const isPassword = pwInput.type === 'password';
    pwInput.type = isPassword ? 'text' : 'password';
    eyeOpen.style.display = isPassword ? 'none' : 'block';
    eyeClosed.style.display = isPassword ? 'block' : 'none';
  });

  document.getElementById('registerForm').addEventListener('submit', (e) => {
    if (pwInput.value !== pw2Input.value) {
      e.preventDefault();
      pw2Input.setCustomValidity('Passwords do not match');
      pw2Input.reportValidity();
      return;
    }
    pw2Input.setCustomValidity('');
    const btn = document.getElementById('registerBtn');
    btn.innerHTML = `
      <svg class="spin" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
      </svg>
      Creating account...
    `;
    btn.disabled = true;
  });

  document.getElementById('password2').addEventListener('input', function() {
    this.setCustomValidity('');
  });
</script>
</body>
</html>
