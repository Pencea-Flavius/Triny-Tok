<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Reset Password' }) %>
  <link rel="stylesheet" href="/css/login.css">
</head>
<body>
<%- include('partials/nav') %>

<div class="login-wrap">
  <div class="glow-blob blob-a"></div>
  <div class="glow-blob blob-b"></div>
  <div class="login-container" style="justify-content:center;">
    <div class="login-card" style="max-width:400px;">
      <div class="login-header">
        <div class="login-logo">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h1 class="login-title">Forgot password?</h1>
        <p class="login-sub">Enter your email and we'll send you a reset link.</p>
      </div>

      <% if (typeof sent !== 'undefined' && sent) { %>
        <div style="background:rgba(0,242,234,0.08); border:1px solid var(--teal); border-radius:10px; padding:14px 16px; font-size:13px; color:var(--teal); margin-bottom:16px;">
          If that email exists, a reset link has been sent. Check your inbox.
        </div>
      <% } %>

      <form class="login-form" method="POST" action="/password-reset">
        <div class="form-field">
          <label class="form-label" for="email">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
            Email Address
          </label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required autocomplete="email">
        </div>

        <button type="submit" class="btn-login">Send Reset Link</button>
      </form>

      <div class="login-footer-text">
        Remembered it? <a href="/login" class="signup-link">Sign in</a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
</body>
</html>
