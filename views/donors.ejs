<%
const diamondSvg = '<svg width="11" height="11" viewBox="0 0 640 640" fill="currentColor" style="vertical-align:middle;margin-right:2px;flex-shrink:0;"><path d="M232.5 136L320 229L407.5 136L232.5 136zM447.9 163.1L375.6 240L504.6 240L448 163.1zM497.9 288L142.1 288L320 484.3L497.9 288zM135.5 240L264.5 240L192.2 163.1L135.6 240zM569.8 280.1L337.8 536.1C333.3 541.1 326.8 544 320 544C313.2 544 306.8 541.1 302.2 536.1L70.2 280.1C62.5 271.6 61.9 258.9 68.7 249.7L180.7 97.7C185.2 91.6 192.4 87.9 200 87.9L440 87.9C447.6 87.9 454.8 91.5 459.3 97.7L571.3 249.7C578.1 258.9 577.4 271.6 569.8 280.1z"/></svg>';
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Your Donors' }) %>
  <link rel="stylesheet" href="/css/login.css">
  <style>
    .page-wrap {
      min-height: 100vh;
      padding: 90px 48px 80px;
      max-width: 960px;
      margin: 0 auto;
    }

    .page-back {
      display: inline-flex; align-items: center; gap: 7px;
      font-size: 13px; font-weight: 600; color: var(--muted);
      text-decoration: none; margin-bottom: 36px;
      transition: color 0.15s;
    }
    .page-back:hover { color: var(--teal); }

    .page-header {
      display: flex; align-items: flex-end; justify-content: space-between;
      margin-bottom: 32px; flex-wrap: wrap; gap: 16px;
    }
    .page-title {
      font-size: 28px; font-weight: 900; letter-spacing: -0.8px;
      line-height: 1;
    }
    .page-title span { color: var(--teal); }

    .stats-bar {
      display: flex; gap: 12px; flex-wrap: wrap;
    }
    .stat-pill {
      display: flex; align-items: center; gap: 8px;
      padding: 8px 14px; border-radius: 10px;
      background: var(--bg2); border: 1px solid var(--border);
      font-size: 13px; font-weight: 700; color: var(--text);
    }
    .stat-pill .stat-label { color: var(--muted); font-weight: 600; }
    .stat-pill .diamond { color: var(--teal); display:inline-flex;align-items:center; }

    /* Podium */
    .podium {
      display: flex; align-items: flex-end; justify-content: center;
      gap: 12px; margin-bottom: 40px;
    }
    .podium-item {
      display: flex; flex-direction: column; align-items: center;
      gap: 10px; flex: 1; max-width: 200px;
      padding: 20px 16px;
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: 18px; text-align: center;
      position: relative; transition: transform 0.2s;
    }
    .podium-item:hover { transform: translateY(-3px); }
    .podium-1 {
      border-color: rgba(255, 200, 30, 0.3);
      background: linear-gradient(180deg, rgba(255,200,30,0.07) 0%, var(--bg2) 100%);
      order: 2;
    }
    .podium-2 {
      border-color: rgba(180,180,190,0.25);
      background: linear-gradient(180deg, rgba(180,180,190,0.05) 0%, var(--bg2) 100%);
      order: 1;
    }
    .podium-3 {
      border-color: rgba(200,130,50,0.25);
      background: linear-gradient(180deg, rgba(200,130,50,0.05) 0%, var(--bg2) 100%);
      order: 3;
    }
    .podium-medal {
      font-size: 22px; line-height: 1;
    }
    .podium-avatar {
      width: 60px; height: 60px; border-radius: 50%;
      object-fit: cover; flex-shrink: 0;
      border: 2px solid rgba(0,242,234,0.2);
    }
    .podium-1 .podium-avatar { border-color: rgba(255,200,30,0.5); width: 72px; height: 72px; }
    .podium-avatar-fallback {
      width: 60px; height: 60px; border-radius: 50%;
      display: none; align-items: center; justify-content: center;
      font-size: 22px; font-weight: 900; color: var(--teal);
      border: 2px solid rgba(0,242,234,0.2);
      background: rgba(0,242,234,0.08);
    }
    .podium-1 .podium-avatar-fallback { width: 72px; height: 72px; }
    .podium-name {
      font-size: 13px; font-weight: 800; color: var(--text);
      max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .podium-nick {
      font-size: 11px; color: var(--muted); margin-top: -6px;
      max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .podium-diamonds {
      font-size: 14px; font-weight: 900; color: var(--teal);
    }
    .podium-count {
      font-size: 11px; color: var(--dim);
    }

    /* Table */
    .donors-table-wrap {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: 16px; overflow: hidden;
    }
    .donors-table {
      width: 100%; border-collapse: collapse;
    }
    .donors-table thead th {
      padding: 14px 20px;
      font-size: 10px; font-weight: 800; letter-spacing: 1.2px;
      text-transform: uppercase; color: var(--dim);
      border-bottom: 1px solid rgba(255,255,255,0.04);
      text-align: left;
    }
    .donors-table thead th:last-child { text-align: right; }
    .donors-table tbody tr {
      border-bottom: 1px solid rgba(255,255,255,0.03);
      transition: background 0.12s;
    }
    .donors-table tbody tr:last-child { border-bottom: none; }
    .donors-table tbody tr:hover { background: rgba(255,255,255,0.025); }
    .donors-table td {
      padding: 14px 20px; vertical-align: middle;
    }
    .rank-cell {
      font-size: 12px; font-weight: 800; color: var(--dim);
      width: 48px; text-align: center;
    }
    .donor-cell {
      display: flex; align-items: center; gap: 12px;
    }
    .donor-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      object-fit: cover; flex-shrink: 0;
      border: 1px solid rgba(0,242,234,0.15);
    }
    .donor-avatar-fallback {
      width: 36px; height: 36px; border-radius: 50%;
      display: none; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 900; color: var(--teal);
      background: rgba(0,242,234,0.08);
      border: 1px solid rgba(0,242,234,0.15);
      flex-shrink: 0;
    }
    .donor-info-name { font-size: 13px; font-weight: 800; color: var(--text); }
    .donor-info-nick { font-size: 11px; color: var(--muted); margin-top: 1px; }
    .diamonds-cell {
      font-size: 14px; font-weight: 900; color: var(--teal); text-align: right;
    }
    .diamonds-cell small { font-size: 11px; font-weight: 600; opacity: 0.6; }
    .count-cell {
      font-size: 13px; color: var(--dim); text-align: right;
    }

    .empty-state {
      padding: 72px 24px; text-align: center; color: var(--dim);
    }
    .empty-state svg { opacity: 0.3; margin-bottom: 16px; }
    .empty-state p { font-size: 14px; }

    /* Pagination */
    .pagination {
      display: flex; align-items: center; justify-content: center;
      gap: 8px; margin-top: 28px;
    }
    .page-btn {
      display: inline-flex; align-items: center; justify-content: center;
      width: 36px; height: 36px; border-radius: 8px;
      font-size: 13px; font-weight: 700; text-decoration: none;
      border: 1px solid var(--border); color: var(--muted);
      background: var(--bg2); transition: all 0.15s;
    }
    .page-btn:hover { border-color: var(--teal); color: var(--teal); }
    .page-btn.active { background: var(--teal); color: #060912; border-color: var(--teal); }
    .page-btn.disabled { opacity: 0.3; pointer-events: none; }

    @media (max-width: 640px) {
      .page-wrap { padding: 90px 20px 60px; }
      .podium { gap: 8px; }
      .podium-item { padding: 14px 10px; }
      .donors-table thead { display: none; }
      .donors-table td { padding: 12px 14px; }
      .rank-cell { width: 32px; }
    }
  </style>
</head>
<body>
<%- include('partials/nav') %>

<div class="page-wrap">
  <div class="glow-blob blob-a" style="opacity:0.04;"></div>

  <a href="/account" class="page-back">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    Back to account
  </a>

  <div class="page-header">
    <div>
      <div class="page-title">Your <span>Donors</span></div>
      <div style="font-size:13px;color:var(--muted);margin-top:6px;">Everyone who has ever supported your streams</div>
    </div>
    <div class="stats-bar">
      <div class="stat-pill">
        <span class="stat-label">Donors</span>
        <span><%= total.toLocaleString() %></span>
      </div>
      <div class="stat-pill">
        <span class="diamond"><%- diamondSvg %></span>
        <span class="stat-label">Total</span>
        <span><%= (totalDiamonds || 0).toLocaleString() %></span>
      </div>
    </div>
  </div>

  <% if (donors.length === 0) { %>
  <div class="donors-table-wrap">
    <div class="empty-state">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      <p>No donors yet — go live and start collecting gifts!</p>
    </div>
  </div>
  <% } else { %>

  <%
    const offset = (page - 1) * pageSize;
    const top3 = donors.filter((_, i) => i < 3 && offset === 0);
    const rest = offset === 0 ? donors.slice(3) : donors;
  %>

  <% if (top3.length > 0) { %>
  <div class="podium">
    <% top3.forEach((d, i) => { %>
    <div class="podium-item podium-<%= i + 1 %>">
      <div class="podium-medal"><%= ['🥇','🥈','🥉'][i] %></div>
      <img
        src="https://unavatar.io/tiktok/<%= d.uniqueId %>"
        alt="<%= d.uniqueId %>"
        class="podium-avatar"
        id="pa-<%= i %>"
        onerror="this.style.display='none';document.getElementById('paf-<%= i %>').style.display='flex';"
      >
      <div class="podium-avatar-fallback" id="paf-<%= i %>">
        <%= (d.nickname || d.uniqueId || '?').charAt(0).toUpperCase() %>
      </div>
      <div>
        <div class="podium-name">@<%= d.uniqueId %></div>
        <% if (d.nickname && d.nickname !== d.uniqueId) { %>
        <div class="podium-nick"><%= d.nickname %></div>
        <% } %>
      </div>
      <div class="podium-diamonds"><%- diamondSvg %> <%= d.totalDiamonds.toLocaleString() %></div>
      <div class="podium-count"><%= d.donationCount %> gift<%= d.donationCount !== 1 ? 's' : '' %></div>
    </div>
    <% }) %>
  </div>
  <% } %>

  <div class="donors-table-wrap">
    <table class="donors-table">
      <thead>
        <tr>
          <th style="text-align:center;">#</th>
          <th>Donor</th>
          <th style="text-align:right;">Gifts sent</th>
          <th style="text-align:right;">Total diamonds</th>
        </tr>
      </thead>
      <tbody>
        <% rest.forEach((d, i) => { %>
        <%
          const rank = offset + (top3.length > 0 ? i + 4 : i + 1);
          const avatarId = 'da-' + rank;
          const fallbackId = 'daf-' + rank;
        %>
        <tr>
          <td class="rank-cell"><%= rank %></td>
          <td>
            <div class="donor-cell">
              <img
                src="https://unavatar.io/tiktok/<%= d.uniqueId %>"
                alt="<%= d.uniqueId %>"
                class="donor-avatar"
                id="<%= avatarId %>"
                onerror="this.style.display='none';document.getElementById('<%= fallbackId %>').style.display='flex';"
              >
              <div class="donor-avatar-fallback" id="<%= fallbackId %>">
                <%= (d.nickname || d.uniqueId || '?').charAt(0).toUpperCase() %>
              </div>
              <div>
                <div class="donor-info-name">@<%= d.uniqueId %></div>
                <% if (d.nickname && d.nickname !== d.uniqueId) { %>
                <div class="donor-info-nick"><%= d.nickname %></div>
                <% } %>
              </div>
            </div>
          </td>
          <td class="count-cell"><%= d.donationCount %></td>
          <td class="diamonds-cell"><%- diamondSvg %> <%= d.totalDiamonds.toLocaleString() %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% const totalPages = Math.ceil(total / pageSize); %>
  <% if (totalPages > 1) { %>
  <div class="pagination">
    <a href="?page=<%= page - 1 %>" class="page-btn <%= page <= 1 ? 'disabled' : '' %>">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </a>
    <% for (let p = Math.max(1, page - 2); p <= Math.min(totalPages, page + 2); p++) { %>
    <a href="?page=<%= p %>" class="page-btn <%= p === page ? 'active' : '' %>"><%= p %></a>
    <% } %>
    <a href="?page=<%= page + 1 %>" class="page-btn <%= page >= totalPages ? 'disabled' : '' %>">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </a>
  </div>
  <% } %>

  <% } %>
</div>

<%- include('partials/footer') %>
</body>
</html>
