# Session secret — change this to a random string in production
SESSION_SECRET=change-me-to-a-random-secret

# SMTP config for email verification and password reset
# Example using Gmail (use an App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Optional: TikTok session ID for live connection
# SESSIONID=

# Twitch API credentials — required for AI game suggestion (trending games)
# Register your app at https://dev.twitch.tv/console → click "New Secret" to get the secret
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# Ollama config — required for AI preset generation
# Make sure Ollama is running locally: https://ollama.com
# Pull the model first: ollama pull qwen2.5:7b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
